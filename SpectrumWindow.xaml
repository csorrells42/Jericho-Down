<Window x:Class="PodcastWorkbench.SpectrumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Microphone Spectrum"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#05070A"
        KeyDown="WindowKeyDown"
        Loaded="WindowLoaded"
        Activated="WindowActivated"
        Deactivated="WindowDeactivated"
        Closing="WindowClosing">
    <Grid>
        <Canvas x:Name="SpectrumCanvas" Background="#05070A" />
        <Border HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="#BB111820"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Microphone Spectrum" Foreground="#F8FAFC" FontSize="24" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Mic" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="MicrophoneComboBox"
                                  Width="300"
                                  SelectionChanged="MicrophoneSelectionChanged" />
                        <TextBlock Text="Gain" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="14,0,8,0" />
                        <Slider x:Name="DisplayGainSlider"
                                Width="140"
                                Minimum="1"
                                Maximum="24"
                                Value="6"
                                VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText"
                                   Text="Listening while this window is active"
                                   Foreground="#B8C7D9"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="PeakText" Text="Peak 0%" Foreground="#F8FAFC" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <Button Content="Close"
                            Click="CloseClicked"
                            Padding="14,7" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>


