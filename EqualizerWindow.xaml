                <Rectangle Fill="#05070A" />
                <Image x:Name="CameraPreviewImage" Visibility="Collapsed" Stretch="Uniform" SnapsToDevicePixels="True" />
                <MediaElement x:Name="SessionPlaybackElement" Visibility="Collapsed" LoadedBehavior="Manual" UnloadedBehavior="Manual" ScrubbingEnabled="True" Stretch="Uniform" MediaOpened="SessionPlaybackOpened" MediaEnded="SessionPlaybackEnded" MediaFailed="SessionPlaybackFailed" />
