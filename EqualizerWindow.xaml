                            <TextBlock Text="Parity" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <ComboBox x:Name="SerialParityComboBox" Width="78" />
                            <TextBlock Text="Stop" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <ComboBox x:Name="SerialStopBitsComboBox" Width="70" />
                            <TextBlock Text="Flow" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="12,0,6,0" />
