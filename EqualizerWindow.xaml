                                           Foreground="#B8C7D9"
                                           VerticalAlignment="Center"
                                           Margin="10,0,6,0" />
                                <ComboBox x:Name="MqttSubscribeQosComboBox" Width="52" />
                                <Button Content="Subscribe"
                                        Padding="12,6"
                                        Margin="8,0,0,0"
                                        Click="MqttSubscribeClicked" />
                            </StackPanel>

                            <Rectangle Grid.Column="1"
                                       Width="1"
                                       Fill="#334F5D6B"
                                       Margin="14,0" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Publish"
                                           Foreground="#F8FAFC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBox x:Name="MqttPublishTopicTextBox"
                                         Text="test/topic"
                                         Width="220" />
                                <TextBlock Text="QoS"
                                           Foreground="#B8C7D9"
                                           VerticalAlignment="Center"
                                           Margin="10,0,6,0" />
                                <ComboBox x:Name="MqttPublishQosComboBox" Width="52" />
                                <CheckBox x:Name="MqttRetainCheckBox"
                                          Content="Retain"
                                          Foreground="#F8FAFC"
                                          VerticalAlignment="Center"
                                          Margin="10,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#AA111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Built-in Broker"
                                       Foreground="#F8FAFC"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <TextBlock Text="Port"
                                       Foreground="#B8C7D9"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBox x:Name="MqttBrokerPortTextBox"
                                     Text="1883"
                                     Width="62"
                                     TextAlignment="Center" />
                            <CheckBox x:Name="MqttBrokerLocalOnlyCheckBox"
                                      Content="Local only"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      VerticalAlignment="Center"
                                      Margin="12,0,8,0">
                                <CheckBox.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Binds the test broker to 127.0.0.1 so only this computer can connect. Uncheck only on a trusted network." />
                                </CheckBox.ToolTip>
                            </CheckBox>
                            <Button x:Name="StartMqttBrokerButton"
                                    Content="Start Broker"
                                    Padding="14,7"
                                    Margin="4,0,6,0"
                                    Click="StartMqttBrokerClicked" />
                            <Button x:Name="StopMqttBrokerButton"
                                    Content="Stop Broker"
                                    Padding="14,7"
                                    IsEnabled="False"
                                    Click="StopMqttBrokerClicked" />
                            <Button Content="Use Local"
                                    Padding="14,7"
                                    Margin="6,0,12,0"
                                    Click="UseLocalMqttBrokerClicked">
                                <Button.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Fills the MQTT client settings with localhost and the built-in broker port." />
                                </Button.ToolTip>
                            </Button>
                            <TextBlock x:Name="MqttBrokerStatusText"
                                       Text="Built-in broker stopped."
                                       Foreground="#B8C7D9"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </WrapPanel>
                    </Border>

                    <DataGrid x:Name="MqttLogGrid"
                              Grid.Row="3"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              Background="#0B1118"
                              Foreground="#F8FAFC"
                              BorderBrush="#334F5D6B"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#111820"
                              AlternatingRowBackground="#162231">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding TimeLabel}" Width="105" />
                            <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="55" />
                            <DataGridTextColumn Header="Topic" Binding="{Binding Topic}" Width="220" />
                            <DataGridTextColumn Header="QoS" Binding="{Binding QualityOfService}" Width="55" />
                            <DataGridTextColumn Header="Retain" Binding="{Binding RetainedLabel}" Width="70" />
                            <DataGridTextColumn Header="Payload" Binding="{Binding Payload}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="4"
                            Background="#66111820"
                            Padding="14"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MqttPayloadTextBox"
                                     MinHeight="70"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <Button Content="Publish"
                                        Padding="16,7"
                                        Margin="0,0,0,6"
                                        Click="MqttPublishClicked" />
                                <Button Content="Clear"
                                        Padding="16,7"
                                        Click="ClearMqttLogClicked" />
                            </StackPanel>
                            <TextBlock x:Name="MqttStatusText"
                                       Grid.ColumnSpan="2"
                                       Text="MQTT disconnected."
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,100,0" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

