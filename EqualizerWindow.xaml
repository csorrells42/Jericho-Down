                                    Margin="12,0,6,0"
                                    Click="SerialConnectClicked" />
                            <Button x:Name="SerialDisconnectButton"
                                    Content="Disconnect"
                                    Padding="14,7"
                                    IsEnabled="False"
                                    Click="SerialDisconnectClicked" />
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <DataGrid x:Name="SerialLogGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Background="#0B1118"
                                  Foreground="#F8FAFC"
                                  BorderBrush="#334F5D6B"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="#111820"
                                  AlternatingRowBackground="#162231">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding TimeLabel}" Width="105" />
                                <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="55" />
                                <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="2*" />
                                <DataGridTextColumn Header="Hex" Binding="{Binding Hex}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="#66111820"
                            Padding="14"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SerialSendTextBox"
                                     Grid.Column="0"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center"
                                     AcceptsReturn="False" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                <CheckBox x:Name="SerialSendHexCheckBox"
                                          Content="HEX"
                                          Foreground="#F8FAFC"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                <ComboBox x:Name="SerialLineEndingComboBox" Width="80" />
                                <Button Content="Send" Padding="14,7" Margin="8,0,0,0" Click="SerialSendClicked" />
                                <Button Content="Clear" Padding="14,7" Margin="8,0,0,0" Click="ClearSerialLogClicked" />
                            </StackPanel>
                            <TextBlock x:Name="SerialStatusText"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="Serial disconnected."
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Modbus">
                <Grid Background="#05070A" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#C0111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Mode" Foreground="#F8FAFC" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox x:Name="ModbusModeComboBox"
                                      Width="76"
                                      SelectionChanged="ModbusModeChanged" />

                            <TextBlock x:Name="ModbusTcpHostLabel" Text="Host" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="14,0,6,0" />
                            <TextBox x:Name="ModbusTcpHostTextBox" Text="192.168.1.10" Width="150" />
                            <TextBlock x:Name="ModbusTcpPortLabel" Text="Port" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                            <TextBox x:Name="ModbusTcpPortTextBox" Text="502" Width="58" TextAlignment="Center" />

                            <TextBlock x:Name="ModbusRtuPortLabel" Text="COM" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="14,0,6,0" />
                            <ComboBox x:Name="ModbusRtuPortComboBox" Width="92" />
                            <Button x:Name="RefreshModbusSerialPortsButton"
                                    Content="Refresh"
                                    Padding="10,6"
                                    Margin="6,0,12,0"
                                    Click="RefreshModbusSerialPortsClicked" />
                            <TextBlock x:Name="ModbusRtuBaudLabel" Text="Baud" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox x:Name="ModbusRtuBaudComboBox" Width="90" />
                            <TextBlock x:Name="ModbusRtuDataLabel" Text="Data" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                            <ComboBox x:Name="ModbusRtuDataBitsComboBox" Width="56" />
                            <TextBlock x:Name="ModbusRtuParityLabel" Text="Parity" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                            <ComboBox x:Name="ModbusRtuParityComboBox" Width="78" />
                            <TextBlock x:Name="ModbusRtuStopLabel" Text="Stop" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                            <ComboBox x:Name="ModbusRtuStopBitsComboBox" Width="70" />

                            <TextBlock Text="Unit" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="14,0,6,0" />
                            <TextBox x:Name="ModbusUnitTextBox" Text="1" Width="44" TextAlignment="Center" />
                            <TextBlock Text="Timeout" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                            <TextBox x:Name="ModbusTimeoutTextBox" Text="1000" Width="64" TextAlignment="Center" />
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#AA111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <WrapPanel VerticalAlignment="Center">
                                <TextBlock Text="Function" Foreground="#F8FAFC" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox x:Name="ModbusOperationComboBox"
                                          Width="230"
                                          SelectionChanged="ModbusOperationChanged" />
                                <TextBlock Text="Address" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="14,0,6,0" />
                                <TextBox x:Name="ModbusStartAddressTextBox" Text="0" Width="76" TextAlignment="Center" />
                                <TextBlock x:Name="ModbusCountLabel" Text="Count" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                                <TextBox x:Name="ModbusRequestCountTextBox" Text="1" Width="62" TextAlignment="Center" />
                                <TextBlock x:Name="ModbusValuesLabel" Text="Values" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                                <TextBox x:Name="ModbusValuesTextBox"
                                         Width="230"
                                         Text=""
                                         ToolTip="For writes, enter values separated by spaces or commas. Coils use 0/1. Registers use 0-65535." />
                            </WrapPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="ExecuteModbusButton"
                                        Content="Execute"
                                        Padding="16,7"
                                        Margin="10,0,6,0"
                                        Click="ExecuteModbusClicked" />
                                <Button x:Name="CancelModbusButton"
                                        Content="Cancel"
                                        Padding="16,7"
                                        IsEnabled="False"
                                        Click="CancelModbusClicked" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="ModbusResultsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Background="#0B1118"
                                  Foreground="#F8FAFC"
                                  BorderBrush="#334F5D6B"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="#111820"
                                  AlternatingRowBackground="#162231">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="90" />
                                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="170" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                                <DataGridTextColumn Header="Hex" Binding="{Binding Hex}" Width="130" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1"
                                Background="#AA111820"
                                BorderBrush="#334F5D6B"
                                BorderThickness="1"
                                Padding="14"
                                Margin="12,0,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Transaction"
                                               Foreground="#F8FAFC"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Request"
                                               Foreground="#B8C7D9"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ModbusRequestHexText"
                                               Text="No request yet."
                                               Foreground="#F8FAFC"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,12" />
                                    <TextBlock Text="Response"
                                               Foreground="#B8C7D9"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ModbusResponseHexText"
                                               Text="No response yet."
                                               Foreground="#F8FAFC"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,12" />
                                    <TextBlock Text="Supported"
                                               Foreground="#B8C7D9"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="01/02 coils and discrete inputs, 03/04 registers, 05/06 single writes, 15/16 multiple writes. Addresses are zero-based unless your device manual says otherwise."
                                               Foreground="#B8C7D9"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3"
                            Background="#66111820"
                            Padding="14"
                            Margin="0,12,0,0">
                        <TextBlock x:Name="ModbusStatusText"
                                   Text="Choose TCP or RTU, pick a function, then execute a single selected request."
                                   Foreground="#B8C7D9"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="SQL">
                <Grid Background="#05070A" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#C0111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Server" Foreground="#F8FAFC" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox x:Name="SqlServerTextBox" Text="localhost" Width="160" />
                            <TextBlock Text="Port" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                            <TextBox x:Name="SqlPortTextBox" Text="1433" Width="60" TextAlignment="Center" />
                            <TextBlock Text="Database" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                            <TextBox x:Name="SqlDatabaseTextBox" Text="master" Width="130" />
                            <CheckBox x:Name="SqlWindowsAuthCheckBox"
                                      Content="Windows Auth"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      VerticalAlignment="Center"
                                      Margin="12,0,8,0"
                                      Checked="SqlAuthModeChanged"
                                      Unchecked="SqlAuthModeChanged" />
                            <TextBlock x:Name="SqlUserLabel" Text="User" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="4,0,6,0" />
                            <TextBox x:Name="SqlUserTextBox" Width="110" />
                            <TextBlock x:Name="SqlPasswordLabel" Text="Pass" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,6,0" />
                            <PasswordBox x:Name="SqlPasswordBox" Width="110" />
                            <CheckBox x:Name="SqlEncryptCheckBox"
                                      Content="Encrypt"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      VerticalAlignment="Center"
                                      Margin="12,0,8,0" />
                            <CheckBox x:Name="SqlTrustCertificateCheckBox"
                                      Content="Trust cert"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      VerticalAlignment="Center"
                                      Margin="4,0,8,0">
                                <CheckBox.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Useful for plant-floor or lab SQL Servers with self-signed certificates. Leave off for fully trusted production certificates." />
                                </CheckBox.ToolTip>
                            </CheckBox>
                            <Button x:Name="SqlConnectButton"
                                    Content="Connect"
                                    Padding="14,7"
                                    Margin="6,0,6,0"
                                    Click="SqlConnectClicked" />
                            <Button x:Name="SqlDisconnectButton"
                                    Content="Disconnect"
                                    Padding="14,7"
                                    IsEnabled="False"
                                    Click="SqlDisconnectClicked" />
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#AA111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SqlQueryTextBox"
                                     Text="SELECT TOP (100) name, database_id, create_date FROM sys.databases ORDER BY name;"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="13" />
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <CheckBox x:Name="SqlAllowWritesCheckBox"
                                          Content="Allow writes"
                                          Foreground="#F8FAFC"
                                          Margin="0,0,0,8">
                                    <CheckBox.ToolTip>
                                        <TextBlock Style="{StaticResource WrappedToolTipText}" Text="When unchecked, only SELECT and WITH queries are allowed from this quick tool." />
                                    </CheckBox.ToolTip>
                                </CheckBox>
                                <TextBlock Text="Timeout"
                                           Foreground="#B8C7D9"
                                           Margin="0,0,0,4" />
                                <TextBox x:Name="SqlTimeoutTextBox"
                                         Text="30"
                                         Width="72"
                                         TextAlignment="Center"
                                         Margin="0,0,0,8" />
                                <Button x:Name="SqlExecuteButton"
                                        Content="Execute"
                                        Padding="16,7"
                                        Margin="0,0,0,6"
                                        Click="SqlExecuteClicked" />
                                <Button x:Name="SqlCancelButton"
                                        Content="Cancel"
                                        Padding="16,7"
                                        IsEnabled="False"
                                        Click="SqlCancelClicked" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="SqlResultsGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              Background="#0B1118"
                              Foreground="#F8FAFC"
                              BorderBrush="#334F5D6B"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#111820"
                              AlternatingRowBackground="#162231" />

                    <Border Grid.Row="3"
                            Background="#66111820"
                            Padding="14"
                            Margin="0,12,0,0">
                        <TextBlock x:Name="SqlStatusText"
                                   Text="SQL disconnected. This is a quick SQL Server tool for pinch queries; SSMS is still the full cockpit."
                                   Foreground="#B8C7D9"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="MQTT">
