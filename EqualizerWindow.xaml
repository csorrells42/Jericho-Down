              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#E2E8F0" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="SwitchTrack" Property="Background" Value="#26323D" />
                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#64748B" />
                <Setter Property="Foreground" Value="#64748B" />
