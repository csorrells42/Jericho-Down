                      <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Starts the waveform near a rising center crossing so the display behaves more like a triggered oscilloscope." />
                    </CheckBox.ToolTip>
                  </CheckBox>
                </StackPanel>
                <StackPanel x:Name="AnalyzerSmoothingPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
