            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>
            <Border Background="#030507" BorderBrush="#334F5D6B" BorderThickness="1">
