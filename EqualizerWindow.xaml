                          <Rectangle Height="1" Fill="#FFFFFF" Opacity="0.13" VerticalAlignment="Top" Margin="0,-1,8,0" />
                          <ContentPresenter Content="{Binding Content, ElementName=SelectedComboContent}" ContentTemplate="{Binding ContentTemplate, ElementName=SelectedComboContent}" ContentStringFormat="{Binding ContentStringFormat, ElementName=SelectedComboContent}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,6,0" />
                          <Border Grid.Column="1" Width="18" Height="18" Background="#0E4F4A" BorderBrush="#35E8D8" BorderThickness="1" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Center">
