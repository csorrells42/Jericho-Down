    <Style TargetType="Slider">
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid SnapsToDevicePixels="True" Margin="0,2">
              <Grid.RowDefinitions>
                <RowDefinition Height="22" />
                <RowDefinition Height="4" />
              </Grid.RowDefinitions>
              <Border Height="18" VerticalAlignment="Center" Background="#05090C" BorderBrush="#24394A" BorderThickness="1" CornerRadius="5" />
              <Border Height="8" VerticalAlignment="Center" Margin="8,0" CornerRadius="4" Opacity="0.96">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#061017" Offset="0" />
                    <GradientStop Color="#0C2638" Offset="0.44" />
                    <GradientStop Color="#164961" Offset="0.5" />
                    <GradientStop Color="#0C2638" Offset="0.56" />
                    <GradientStop Color="#061017" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Rectangle Height="3" Fill="#25E0D0" VerticalAlignment="Center" Margin="10,0" Opacity="0.34" RadiusX="1.5" RadiusY="1.5" />
              <Rectangle Height="1" Fill="#9CFDF4" VerticalAlignment="Center" Margin="10,0" Opacity="0.9" />
              <Track x:Name="PART_Track" Height="22" VerticalAlignment="Center" Margin="5,0">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" IsTabStop="False" Focusable="False" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" IsTabStop="False" Focusable="False" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Width="10" Height="20">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border Width="10" Height="20" BorderBrush="#A7FFF8" BorderThickness="1" CornerRadius="2" SnapsToDevicePixels="True">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                              <GradientStop Color="#0E4F4A" Offset="0" />
                              <GradientStop Color="#35E8D8" Offset="0.48" />
                              <GradientStop Color="#0E4F4A" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                        </Border>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
              <TickBar Grid.Row="1" Margin="5,-1,5,0" Height="4" Fill="#F4C542" Placement="Bottom" ReservedSpace="10" Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}" Ticks="{TemplateBinding Ticks}" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
