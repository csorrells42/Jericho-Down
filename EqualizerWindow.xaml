                      <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Shows input 1 and input 2 as raw, unprocessed spectrum lines so two microphones can be compared directly." />
                    </ToggleButton.ToolTip>
                  </ToggleButton>
                </StackPanel>
                <StackPanel x:Name="WaveformOptionsPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0" Visibility="Collapsed">
