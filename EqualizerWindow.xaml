  </Window.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="#0B1118" BorderBrush="#26323D" BorderThickness="0,0,0,1" Padding="8,0">
      <Menu Background="Transparent" Foreground="#F8FAFC" FontSize="13">
        <Menu.Resources>
          <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#0B1118" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Padding" Value="10,4" />
          </Style>
        </Menu.Resources>
        <MenuItem Header="_File">
          <MenuItem Header="Refresh Audio Devices" Click="RefreshAudioDevicesMenuClicked" />
          <MenuItem Header="Refresh Video Devices" Click="RefreshVideoDevicesMenuClicked" />
          <Separator />
          <MenuItem Header="Settings">
            <MenuItem Header="Podcast Settings" Click="PodcastSettingsMenuClicked" />
            <MenuItem Header="Karaoke Settings" Click="KaraokeSettingsMenuClicked" />
          </MenuItem>
          <MenuItem Header="ASIO Settings" Click="AsioSettingsMenuClicked" />
        </MenuItem>
        <MenuItem Header="_Help">
          <MenuItem Header="About" Click="AboutMenuClicked" />
        </MenuItem>
      </Menu>
    </Border>
    <Border Grid.Row="1" Background="#C0111820" Padding="18,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Camera" Foreground="#F8FAFC" VerticalAlignment="Center" Margin="0,0,8,0" />
          <ComboBox x:Name="CameraComboBox" Width="210" SelectionChanged="CameraSelectionChanged" />
          <TextBlock Text="Mode" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="10,0,8,0" />
          <ComboBox x:Name="CameraModeComboBox" Width="190" SelectionChanged="CameraModeSelectionChanged" />
          <ToggleButton x:Name="CameraEnabledToggle" Content="Camera Off" Width="104" Margin="8,0,14,0" Padding="10,6" Checked="CameraEnabledChanged" Unchecked="CameraEnabledChanged">
            <ToggleButton.ToolTip>
              <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Enable or disable webcam capture for this podcast session. The selected camera stays remembered while disabled." />
            </ToggleButton.ToolTip>
          </ToggleButton>
          <TextBlock x:Name="StatusText" Text="Ready" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="14,0,0,0" />
        </StackPanel>
      </Grid>
    </Border>
    <TabControl x:Name="MainTabControl" Grid.Row="2" Background="#05070A" BorderBrush="#26323D" BorderThickness="1" Foreground="#F8FAFC" Padding="4,3,4,4" SelectionChanged="MainTabSelectionChanged">
      <TabControl.Resources>
        <Style TargetType="TabItem">
          <Setter Property="Padding" Value="16,6" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Background" Value="#111820" />
          <Setter Property="Foreground" Value="#B8C7D9" />
          <Setter Property="BorderBrush" Value="#334F5D6B" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="Margin" Value="0,0,2,0" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="TabItem">
                <Grid SnapsToDevicePixels="True">
                  <Border x:Name="TabChrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,1,0" CornerRadius="2,2,0,0" Padding="{TemplateBinding Padding}">
                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}" RecognizesAccessKey="True" />
                  </Border>
                  <Rectangle x:Name="SelectedUnderline" Height="2" Fill="#38BDF8" VerticalAlignment="Bottom" Visibility="Collapsed" />
                </Grid>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="TabChrome" Property="Background" Value="#18222B" />
                    <Setter TargetName="TabChrome" Property="BorderBrush" Value="#334F5D6B" />
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="TabChrome" Property="Background" Value="#0B1118" />
                    <Setter TargetName="TabChrome" Property="BorderBrush" Value="#334F5D6B" />
                    <Setter TargetName="SelectedUnderline" Property="Visibility" Value="Visible" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
          <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="#0B1118" />
              <Setter Property="Foreground" Value="#FFFFFF" />
              <Setter Property="BorderBrush" Value="#334F5D6B" />
            </Trigger>
          </Style.Triggers>
        </Style>
      </TabControl.Resources>
      <TabItem Header="Podcast">
        <Grid Background="#05070A">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#C0111820" Padding="18,12">
