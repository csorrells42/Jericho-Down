                      <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Controls how much the spectrum analyzer display is smoothed. Lower values react faster; higher values look calmer." />
                    </Slider.ToolTip>
                  </Slider>
                  <TextBlock Text="{Binding ElementName=AnalyzerSmoothingSlider, Path=Value, StringFormat={}{0:0}%}" Foreground="#F8FAFC" Width="38" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
