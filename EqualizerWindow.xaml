                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Subscribe"
                                           Foreground="#F8FAFC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
