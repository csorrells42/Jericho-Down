                      <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Controls how much time the waveform shows. Lower values zoom in and feel faster; higher values zoom out and feel slower." />
                    </Slider.ToolTip>
                  </Slider>
                  <TextBlock Text="{Binding ElementName=WaveformTimeSlider, Path=Value, StringFormat={}{0:0} ms}" Foreground="#F8FAFC" Width="48" VerticalAlignment="Center" Margin="6,0,0,0" />
