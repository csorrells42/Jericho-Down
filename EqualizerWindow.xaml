                <Border x:Name="SessionPlaybackBar" Visibility="Collapsed" VerticalAlignment="Bottom" Background="#E605070A" BorderBrush="#6635E8D8" BorderThickness="1,1,1,0" Padding="12,8" Margin="12" CornerRadius="6">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="SessionPlaybackBarPlayPauseButton" Content="Pause" Width="58" MinHeight="28" Padding="8,3" Margin="0,0,10,0" Click="SessionPlaybackBarPlayPauseClicked" />
                    <TextBlock x:Name="SessionPlaybackPositionText" Grid.Column="1" Text="00:00:00" Foreground="#F8FAFC" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Slider x:Name="SessionPlaybackSeekSlider" Grid.Column="2" Minimum="0" Maximum="1" Value="0" VerticalAlignment="Center" PreviewMouseLeftButtonDown="SessionPlaybackSeekSliderPreviewMouseLeftButtonDown" PreviewMouseMove="SessionPlaybackSeekSliderPreviewMouseMove" PreviewMouseLeftButtonUp="SessionPlaybackSeekSliderPreviewMouseLeftButtonUp" ValueChanged="SessionPlaybackSeekSliderValueChanged">
                      <Slider.Template>
                        <ControlTemplate TargetType="Slider">
                          <Grid SnapsToDevicePixels="True" MinHeight="28">
                            <Border Height="8" VerticalAlignment="Center" Background="#071019" BorderBrush="#345567" BorderThickness="1" CornerRadius="4" />
                            <Rectangle Height="2" Fill="#25E0D0" VerticalAlignment="Center" Margin="10,0" Opacity="0.55" RadiusX="1" RadiusY="1" />
                            <Track x:Name="PART_Track" Height="28" VerticalAlignment="Center" Margin="6,0">
                              <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" IsTabStop="False" Focusable="False" />
                              </Track.DecreaseRepeatButton>
                              <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" IsTabStop="False" Focusable="False" />
                              </Track.IncreaseRepeatButton>
                              <Track.Thumb>
                                <Thumb Width="18" Height="18">
                                  <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                      <Ellipse Width="18" Height="18" Fill="#35E8D8" Stroke="#D8FFFB" StrokeThickness="2" SnapsToDevicePixels="True" />
                                    </ControlTemplate>
                                  </Thumb.Template>
                                </Thumb>
                              </Track.Thumb>
                            </Track>
                          </Grid>
                        </ControlTemplate>
                      </Slider.Template>
                    </Slider>
                    <TextBlock x:Name="SessionPlaybackDurationText" Grid.Column="3" Text="00:00:00" Foreground="#B8C7D9" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0" />
                  </Grid>
                </Border>
              </Grid>
            </Border>
            <Border Grid.Column="1" Background="#AA111820" BorderBrush="#334F5D6B" BorderThickness="1" Padding="14" Margin="14,0,0,0">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,12,14">
                  <TextBlock Text="Audio Confidence" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
