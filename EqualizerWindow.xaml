                        <TextBlock Text="{Binding ElementName=SaturationSlider, Path=Value, StringFormat={}{0:0.0}}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                      </Grid>
                      <Slider x:Name="SaturationSlider" Minimum="0" Maximum="10" Value="{Binding SaturationAmount}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" />
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource DspBubble}">
                    <StackPanel>
                      <TextBlock Text="Makeup Gain" Foreground="#F8FAFC" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
                      <Grid>
                        <TextBlock Text="Makeup dB" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=MakeupGainSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0} dB}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                      </Grid>
                      <Slider x:Name="MakeupGainSlider" Minimum="-6" Maximum="12" Value="{Binding MakeupGainDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" />
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource DspBubble}">
                    <StackPanel>
                      <CheckBox Content="Limiter" IsChecked="{Binding LimiterEnabled}" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,8" />
                      <CheckBox Content="Soft clip peaks" IsChecked="{Binding LimiterSoftClipEnabled}" Foreground="#F8FAFC" Margin="0,0,0,8" />
                      <Grid>
                        <TextBlock Text="Ceiling" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=LimiterCeilingSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0} dB}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                      </Grid>
                      <Slider x:Name="LimiterCeilingSlider" Minimum="-6" Maximum="0" Value="{Binding LimiterCeilingDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,8" />
                      <Grid>
                        <TextBlock Text="Soft clip drive" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=LimiterDriveSlider, Path=Value, StringFormat={}{0:0.0} dB}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                      </Grid>
                      <Slider x:Name="LimiterDriveSlider" Minimum="0" Maximum="12" Value="{Binding LimiterSoftClipDriveDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,8" />
                      <CheckBox Content="Lookahead" IsChecked="{Binding LimiterLookaheadEnabled}" Foreground="#F8FAFC" Margin="0,0,0,8">
                        <CheckBox.ToolTip>
                          <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Adds a tiny delay so the limiter can catch fast peaks before they clip." />
                        </CheckBox.ToolTip>
                      </CheckBox>
                      <Grid>
                        <TextBlock Text="Lookahead" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=LimiterLookaheadSlider, Path=Value, StringFormat={}{0:0.0} ms}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                      </Grid>
                      <Slider x:Name="LimiterLookaheadSlider" Minimum="0" Maximum="20" Value="{Binding LimiterLookaheadMs}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,8" />
                      <Grid>
                        <TextBlock Text="Release" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=LimiterReleaseSlider, Path=Value, StringFormat={}{0:0} ms}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                      </Grid>
                      <Slider x:Name="LimiterReleaseSlider" Minimum="10" Maximum="500" Value="{Binding LimiterReleaseMs}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>
          </Border>
        </Grid>
      </TabItem>
      <TabItem Header="Mic Compare">
        <Grid Background="#05070A">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#C0111820" Padding="18,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Mic 1" Foreground="#FF4848" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="MicCompareMic1DeviceComboBox" Width="240" SelectionChanged="MicCompareMic1DeviceSelectionChanged" Margin="0,0,8,0" />
                <ComboBox x:Name="MicCompareMic1InputModeComboBox" Width="130" SelectionChanged="MicCompareMic1InputModeSelectionChanged" Margin="0,0,18,0" />
                <TextBlock Text="Mic 2" Foreground="#38E66B" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="MicCompareMic2DeviceComboBox" Width="240" SelectionChanged="MicCompareMic2DeviceSelectionChanged" Margin="0,0,8,0" />
                <ComboBox x:Name="MicCompareMic2InputModeComboBox" Width="130" SelectionChanged="MicCompareMic2InputModeSelectionChanged" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock x:Name="MicCompareMic1LegendText" Text="Mic 1" Foreground="#FF4848" VerticalAlignment="Center" />
                <Rectangle Width="24" Height="3" Fill="#FF4848" Margin="6,0,12,0" />
                <TextBlock x:Name="MicCompareMic2LegendText" Text="Mic 2" Foreground="#38E66B" VerticalAlignment="Center" />
                <Rectangle Width="24" Height="3" Fill="#38E66B" Margin="6,0,0,0" />
              </StackPanel>
            </Grid>
          </Border>
          <Border Grid.Row="1" Margin="18" Background="#05070A" BorderBrush="#223544" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
            <Canvas x:Name="MicCompareCanvas" Background="#05070A" ClipToBounds="True" />
          </Border>
        </Grid>
      </TabItem>
      <TabItem Header="Mixing">
        <Grid Background="#05070A">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
          </Grid.ColumnDefinitions>
          <Border Grid.Row="0" Grid.Column="1" Background="#C0111820" Padding="18,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="118" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Master" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,14,0" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Slider x:Name="MasterVolumeSlider" Width="128" Minimum="0" Maximum="150" Value="100" TickFrequency="10" VerticalAlignment="Center" ValueChanged="MasterMixControlChanged" />
                <TextBlock Text="{Binding ElementName=MasterVolumeSlider, Path=Value, StringFormat={}{0:0}%}" Foreground="#F8FAFC" Width="52" VerticalAlignment="Center" Margin="8,0,0,0" />
              </StackPanel>
              <TextBlock Grid.Column="2" Text="Mode" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="8,0,6,0" />
              <ComboBox x:Name="MasterOutputModeComboBox" Grid.Column="3" SelectedIndex="0" SelectionChanged="MasterOutputModeChanged" VerticalAlignment="Center">
                <ComboBoxItem Content="Stereo" />
                <ComboBoxItem Content="Mono" />
              </ComboBox>
              <ToggleButton x:Name="MasterNormalizeToggle" Grid.Column="4" Style="{StaticResource PresetConsoleButton}" Content="Normalize" IsChecked="True" Padding="10,4" Margin="8,0,0,0" Checked="MasterMixControlChanged" Unchecked="MasterMixControlChanged" />
              <ToggleButton x:Name="MasterLimiterToggle" Grid.Column="5" Style="{StaticResource PresetConsoleButton}" Content="Limiter" IsChecked="True" Padding="10,4" Margin="8,0,0,0" Checked="MasterMixControlChanged" Unchecked="MasterMixControlChanged" />
              <TextBlock Grid.Column="6" Text="Ceiling" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="14,0,8,0" />
              <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                <Slider x:Name="MasterLimiterCeilingSlider" Width="128" Minimum="-12" Maximum="0" Value="-1" TickFrequency="1" VerticalAlignment="Center" ValueChanged="MasterMixControlChanged" />
                <TextBlock Text="{Binding ElementName=MasterLimiterCeilingSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0} dB}" Foreground="#F8FAFC" Width="70" VerticalAlignment="Center" Margin="8,0,0,0" />
              </StackPanel>
              <TextBlock x:Name="MixBusStatusText" Grid.Column="8" Text="Bus: processed output" Foreground="#8DA2B7" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
          </Border>
          <Grid Grid.Row="1" Grid.Column="1" Margin="18,14,18,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource DspBubble}" Padding="12" Margin="0,0,10,0">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                  <TextBlock Text="Output spectrum" Foreground="#F8FAFC" FontSize="14" FontWeight="SemiBold" DockPanel.Dock="Left" />
                  <WrapPanel x:Name="MixingMicLegendPanel" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                </DockPanel>
                <Border Grid.Row="1" Background="#050B10" BorderBrush="#223544" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                  <Grid ClipToBounds="True">
                    <ContentControl x:Name="MixingMicSpectrumGraphHost" Focusable="False" ClipToBounds="True" />
                    <Canvas x:Name="MixingMicSpectrumCanvas" Background="#050B10" ClipToBounds="True" Visibility="Collapsed" />
                  </Grid>
                </Border>
              </Grid>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource DspBubble}" Padding="12" Margin="10,0,0,0">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                  <TextBlock Text="Program output" Foreground="#F8FAFC" FontSize="14" FontWeight="SemiBold" />
                  <TextBlock Text="DX12 3D" Foreground="#8DA2B7" FontSize="11" HorizontalAlignment="Right" />
                </DockPanel>
                <Border Grid.Row="1" Background="#050B10" BorderBrush="#223544" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                  <ContentControl x:Name="MixingOutputWaveform3DHost" Focusable="False" ClipToBounds="True" />
                </Border>
              </Grid>
            </Border>
          </Grid>
          <ScrollViewer Grid.Row="2" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Border Style="{StaticResource DspBubble}" Margin="18" Padding="12">
              <ItemsControl x:Name="MixingChannelsItemsControl">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border MinHeight="490" MinWidth="92" BorderThickness="1" CornerRadius="6" Padding="7" Margin="3" SnapsToDevicePixels="True" UseLayoutRounding="True" PreviewMouseLeftButtonDown="MixerChannelStripPreviewMouseLeftButtonDown">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="#071017" />
                          <Setter Property="BorderBrush" Value="#334B5C" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                              <Setter Property="Background" Value="#0A1822" />
                              <Setter Property="BorderBrush" Value="#35E8D8" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="*" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0" Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="#F8FAFC" FontWeight="SemiBold" Background="#081017" BorderBrush="#334B5C" Padding="5,3" TextAlignment="Center" TextChanged="MixerChannelNameChanged" />
                        <TextBlock Grid.Row="1" Text="{Binding RouteText}" Foreground="#8DA2B7" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" ToolTip="{Binding RouteText}" MaxHeight="44" Margin="0,6,0,8" />
                        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,8">
                          <CheckBox Content="Mute" IsChecked="{Binding IsMuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Checked="MixerChannelControlChanged" Unchecked="MixerChannelControlChanged" />
                        </StackPanel>
                        <Slider Grid.Row="3" Style="{StaticResource MixerFaderSlider}" Minimum="0" Maximum="150" Value="{Binding VolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="10" HorizontalAlignment="Center" ValueChanged="MixerChannelControlChanged" />
                        <Grid Grid.Row="4" Margin="0,8,0,8">
                          <TextBlock Text="{Binding VolumeDisplayText}" Foreground="#F8FAFC" FontWeight="SemiBold" HorizontalAlignment="Center" />
                          <Ellipse Width="9" Height="9" Stroke="#D7FFF9" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Ellipse.Style>
                              <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#334B5C" />
                                <Setter Property="Opacity" Value="0.45" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                    <Setter Property="Fill" Value="#DA5048" />
                                    <Setter Property="Opacity" Value="1" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Ellipse.Style>
                          </Ellipse>
                        </Grid>
                        <Border Grid.Row="5" Height="18" BorderBrush="#344B5C" BorderThickness="1" CornerRadius="5" ClipToBounds="True">
                          <Grid>
                            <Rectangle Fill="#10202A" />
                            <Rectangle Fill="#8DA2B7" HorizontalAlignment="Stretch" Opacity="0.58" RadiusX="4" RadiusY="4" RenderTransformOrigin="0,0.5">
                              <Rectangle.RenderTransform>
                                <ScaleTransform ScaleX="{Binding RmsMeterScale}" />
                              </Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Fill="#35E8D8" HorizontalAlignment="Stretch" Height="9" VerticalAlignment="Center" RadiusX="4" RadiusY="4" RenderTransformOrigin="0,0.5">
                              <Rectangle.RenderTransform>
                                <ScaleTransform ScaleX="{Binding LevelMeterScale}" />
                              </Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Fill="#D7B220" HorizontalAlignment="Stretch" Height="2" VerticalAlignment="Top" RenderTransformOrigin="0,0.5">
                              <Rectangle.RenderTransform>
                                <ScaleTransform ScaleX="{Binding PeakHoldMeterScale}" />
                              </Rectangle.RenderTransform>
                            </Rectangle>
                          </Grid>
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>
          </ScrollViewer>
          <Border Grid.RowSpan="3" Grid.Column="0" Background="#AA111820" BorderBrush="#334F5D6B" BorderThickness="0,0,1,0" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel>
                <Border Style="{StaticResource DspBubble}">
                  <StackPanel>
                    <Grid Margin="0,0,0,8">
                      <TextBlock Text="Audio Stability" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" />
                      <Ellipse x:Name="AudioStabilityIndicator" Width="12" Height="12" Fill="#42D77D" Stroke="#D7FFF9" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="AudioStabilityText" Text="Stable: waiting for audio" Foreground="#B8C7D9" TextWrapping="Wrap" />
                    <Border Height="18" BorderBrush="#344B5C" BorderThickness="1" CornerRadius="5" ClipToBounds="True" Margin="0,7,0,0">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                          <GradientStop Color="#05090C" Offset="0" />
                          <GradientStop Color="#0C1820" Offset="0.5" />
                          <GradientStop Color="#05090C" Offset="1" />
                        </LinearGradientBrush>
                      </Border.Background>
                      <Grid>
                        <Rectangle x:Name="AudioStabilityMeter" Fill="#42D77D" HorizontalAlignment="Left" Width="0" RadiusX="4" RadiusY="4" />
                        <Rectangle Height="1" Fill="#FFFFFF" Opacity="0.18" VerticalAlignment="Top" Margin="7,3,7,0" />
                        <Rectangle Height="2" Fill="#9CFDF4" Opacity="0.22" VerticalAlignment="Center" Margin="7,0" RadiusX="1" RadiusY="1" />
                      </Grid>
                    </Border>
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource DspBubble}">
                  <StackPanel>
                    <Grid Margin="0,0,0,8">
                      <TextBlock Text="Output Routing" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" />
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Ellipse x:Name="MasterClipIndicator" Width="10" Height="10" Fill="#334B5C" Stroke="#D7FFF9" StrokeThickness="1" Opacity="0.45" Margin="0,0,5,0" />
                        <TextBlock Text="Clip" Foreground="#B8C7D9" FontSize="11" />
                      </StackPanel>
                    </Grid>
                    <TextBlock Text="Send to" Foreground="#B8C7D9" />
                    <ComboBox x:Name="OutputDeviceComboBox" SelectionChanged="OutputDeviceSelectionChanged" Margin="0,2,0,8" />
                    <ToggleButton x:Name="ProcessedOutputCheckBox" Style="{StaticResource ProcessedOutputToggle}" Content="SEND PROGRAM MIX" Checked="ProcessedOutputChanged" Unchecked="ProcessedOutputChanged" Margin="0,2,0,8">
                      <ToggleButton.ToolTip>
                        <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Sends the final program mix to the selected playback endpoint. To feed podcast software, choose a virtual cable input here, then choose the matching virtual cable output as the mic inside the podcast app." />
                      </ToggleButton.ToolTip>
                    </ToggleButton>
                    <TextBlock x:Name="OutputSignalText" Text="Program mix: waiting for signal" Foreground="#B8C7D9" FontWeight="SemiBold" Margin="0,2,0,0" />
                    <TextBlock x:Name="MasterMeterText" Text="Peak -inf dB | RMS -inf dB" Foreground="#8DA2B7" FontSize="11" Margin="0,2,0,0" />
                    <Border Height="18" BorderBrush="#344B5C" BorderThickness="1" CornerRadius="5" ClipToBounds="True" Margin="0,5,0,0">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                          <GradientStop Color="#05090C" Offset="0" />
                          <GradientStop Color="#0C1820" Offset="0.5" />
                          <GradientStop Color="#05090C" Offset="1" />
                        </LinearGradientBrush>
                      </Border.Background>
                      <Grid>
                        <Rectangle x:Name="OutputRmsMeter" Fill="#8DA2B7" HorizontalAlignment="Left" Width="0" Opacity="0.58" RadiusX="4" RadiusY="4" />
                        <Rectangle x:Name="OutputPeakMeter" Fill="#42D77D" HorizontalAlignment="Left" Width="0" Height="9" VerticalAlignment="Center" RadiusX="4" RadiusY="4" />
                        <Rectangle Height="1" Fill="#FFFFFF" Opacity="0.18" VerticalAlignment="Top" Margin="7,3,7,0" />
                        <Rectangle Height="2" Fill="#9CFDF4" Opacity="0.22" VerticalAlignment="Center" Margin="7,0" RadiusX="1" RadiusY="1" />
                      </Grid>
                    </Border>
                    <Grid Margin="0,8,0,0">
                      <TextBlock x:Name="MasterLimiterReductionText" Text="Limiter GR 0.0 dB" Foreground="#8DA2B7" FontSize="11" />
                      <TextBlock x:Name="MasterLimiterNormalizeText" Text="Normalize 1.00x" Foreground="#8DA2B7" FontSize="11" HorizontalAlignment="Right" />
                    </Grid>
                    <Border Height="10" BorderBrush="#344B5C" BorderThickness="1" CornerRadius="4" ClipToBounds="True" Margin="0,3,0,0">
                      <Grid>
                        <Rectangle Fill="#10202A" />
                        <Rectangle x:Name="MasterLimiterReductionMeter" Fill="#D7B220" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" />
                      </Grid>
                    </Border>
                    <TextBlock x:Name="FeedbackRiskText" Text="Feedback: clear" Foreground="#8DA2B7" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
                    <TextBlock x:Name="OutputStatusText" Text="Output off." Foreground="#B8C7D9" TextWrapping="Wrap" Margin="0,8,0,0" />
                    <TextBlock x:Name="AudioFormatRouteText" Text="Receiving: not open | Trying output: not ready" Foreground="#B8C7D9" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
                    <TextBlock x:Name="OutputAudioSessionsText" Text="Apps on selected output: not checked" Foreground="#8DA2B7" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource DspBubble}">
                  <StackPanel>
                    <TextBlock Text="Recording" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Source" Foreground="#B8C7D9" />
                    <ComboBox x:Name="AudioRecordingSourceComboBox" SelectedIndex="0" SelectionChanged="AudioRecordingSourceChanged" Margin="0,2,0,8">
                      <ComboBoxItem Content="Program mix" />
                      <ComboBoxItem Content="Selected mic" />
                      <ComboBoxItem Content="Selected mic raw backup" />
                    </ComboBox>
                    <TextBlock Text="Save location" Foreground="#B8C7D9" />
                    <Grid Margin="0,3,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBox x:Name="RecordingSaveLocationTextBox" IsReadOnly="True" TextWrapping="NoWrap" ToolTip="{Binding ElementName=RecordingSaveLocationTextBox, Path=Text}" Margin="0,0,8,0" />
                      <Button Grid.Column="1" Style="{StaticResource ConsolePushButton}" Content="Browse" Padding="10,5" Click="BrowseAudioRecordingFolderClicked">
                        <Button.ToolTip>
                          <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Choose where standalone program mix recordings will be saved." />
                        </Button.ToolTip>
                      </Button>
                    </Grid>
                    <UniformGrid Columns="3" Margin="0,10,0,0">
                      <Button x:Name="AudioRecordButton" Style="{StaticResource RecordingRecordButton}" Content="REC" Margin="0,0,4,0" Click="StartAudioRecordingClicked" />
                      <Button x:Name="AudioPauseButton" Style="{StaticResource RecordingPauseButton}" Content="Pause" Margin="4,0" IsEnabled="False" Click="PauseAudioRecordingClicked" />
                      <Button x:Name="AudioStopButton" Style="{StaticResource RecordingStopButton}" Content="Stop" Margin="4,0,0,0" IsEnabled="False" Click="StopAudioRecordingClicked" />
                    </UniformGrid>
                    <TextBlock Text="Saved files" Foreground="#B8C7D9" Margin="0,10,0,3" />
                    <Border BorderBrush="#334B5C" BorderThickness="1" CornerRadius="5" Background="#081017" Height="132" ClipToBounds="True">
                      <ListBox x:Name="RecordingFilesListBox" Background="Transparent" BorderThickness="0" Foreground="#F8FAFC" ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="RecordingFilesSelectionChanged" MouseDoubleClick="RecordingFileDoubleClicked">
                        <ListBox.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Play" Click="PlaySelectedRecordingMenuClicked" />
                            <MenuItem Header="Properties" Click="ShowSelectedRecordingPropertiesMenuClicked" />
                            <MenuItem Header="Export">
                              <MenuItem Header="MP3..." Click="ExportSelectedRecordingMp3MenuClicked" />
                              <MenuItem Header="AAC..." Click="ExportSelectedRecordingAacMenuClicked" />
                              <MenuItem Header="WMA..." Click="ExportSelectedRecordingWmaMenuClicked" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Delete File" Click="DeleteSelectedRecordingMenuClicked" />
                          </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                          <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Foreground" Value="#F8FAFC" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="RecordingFileRightButtonDown" />
                          </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid Margin="8,6">
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                              </Grid.RowDefinitions>
                              <TextBlock Text="{Binding Name}" Foreground="#F8FAFC" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Row="1" Text="{Binding Details}" Foreground="#B8C7D9" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Border>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <Button x:Name="AudioPlayFileButton" Style="{StaticResource RecordingPlayButton}" Content="Play File" Margin="0,0,4,0" Click="PlayAudioFileClicked" />
                      <Button x:Name="AudioOpenLocationButton" Grid.Column="1" Style="{StaticResource RecordingStopButton}" Content="Open Location" Margin="4,0,0,0" Click="OpenAudioRecordingLocationClicked" />
                    </Grid>
                    <TextBlock x:Name="AudioRecordingStatusText" Text="Ready to record the program mix." Foreground="#B8C7D9" TextWrapping="Wrap" Margin="0,8,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Border>
          <Border Grid.RowSpan="3" Grid.Column="2" Background="#AA111820" BorderBrush="#334F5D6B" BorderThickness="1,0,0,0" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel x:Name="SelectedMixerInputPanel">
                <Border Style="{StaticResource DspBubble}">
                  <StackPanel>
                    <TextBlock Text="Selected Input" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding DisplayName}" Foreground="#F8FAFC" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RouteText}" Foreground="#8DA2B7" TextWrapping="Wrap" Margin="0,3,0,10" />
                    <TextBlock Text="Sync" Foreground="#B8C7D9" />
                    <TextBlock Text="{Binding SyncStatusText}" Foreground="#F8FAFC" TextWrapping="Wrap" Margin="0,2,0,10" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Peak / RMS" Foreground="#B8C7D9" VerticalAlignment="Center" />
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Stroke="#D7FFF9" StrokeThickness="1" Margin="0,0,5,0">
                          <Ellipse.Style>
                            <Style TargetType="Ellipse">
                              <Setter Property="Fill" Value="#334B5C" />
                              <Setter Property="Opacity" Value="0.45" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                  <Setter Property="Fill" Value="#DA5048" />
                                  <Setter Property="Opacity" Value="1" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Clip" Foreground="#B8C7D9" FontSize="11" />
                      </StackPanel>
                    </Grid>
                    <Border Height="20" BorderBrush="#344B5C" BorderThickness="1" CornerRadius="5" ClipToBounds="True">
                      <Grid>
                        <Rectangle Fill="#10202A" />
                        <Rectangle Fill="#8DA2B7" HorizontalAlignment="Stretch" Opacity="0.62" RadiusX="4" RadiusY="4" RenderTransformOrigin="0,0.5">
                          <Rectangle.RenderTransform>
                            <ScaleTransform ScaleX="{Binding RmsMeterScale}" />
                          </Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Fill="#35E8D8" HorizontalAlignment="Stretch" Height="9" VerticalAlignment="Center" RadiusX="4" RadiusY="4" RenderTransformOrigin="0,0.5">
                          <Rectangle.RenderTransform>
                            <ScaleTransform ScaleX="{Binding LevelMeterScale}" />
                          </Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Fill="#D7B220" HorizontalAlignment="Stretch" Height="2" VerticalAlignment="Top" RenderTransformOrigin="0,0.5">
                          <Rectangle.RenderTransform>
                            <ScaleTransform ScaleX="{Binding PeakHoldMeterScale}" />
                          </Rectangle.RenderTransform>
                        </Rectangle>
                      </Grid>
                    </Border>
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource DspBubble}">
                  <StackPanel>
                    <TextBlock Text="Channel Controls" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                      <CheckBox Content="Mute" IsChecked="{Binding IsMuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Checked="MixerChannelControlChanged" Unchecked="MixerChannelControlChanged" Margin="0,0,8,6" />
                      <CheckBox Content="Solo" IsChecked="{Binding IsSoloed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Checked="MixerChannelControlChanged" Unchecked="MixerChannelControlChanged" Margin="8,0,0,6" />
                      <CheckBox Content="Invert" IsChecked="{Binding PolarityInverted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Checked="MixerChannelControlChanged" Unchecked="MixerChannelControlChanged" Margin="0,0,8,0">
                        <CheckBox.ToolTip>
                          <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Flips polarity for this input before mixing. Useful when nearby sources cancel each other." />
                        </CheckBox.ToolTip>
                      </CheckBox>
                      <Button Content="Reset" Style="{StaticResource ConsolePushButton}" Padding="10,4" Margin="8,0,0,0" Click="ResetSelectedMixerChannelClicked">
                        <Button.ToolTip>
                          <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Returns this input's mixer controls to center: unmuted, not soloed, normal polarity, 100% volume, 0 dB gain, centered pan, and no delay." />
                        </Button.ToolTip>
                      </Button>
                    </UniformGrid>
                    <Grid>
                      <TextBlock Text="Input gain" Foreground="#B8C7D9" />
                      <TextBlock Text="{Binding InputGainDisplayText}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                    </Grid>
                    <Slider Minimum="-24" Maximum="24" Value="{Binding InputGainDb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="3" ValueChanged="MixerChannelControlChanged" Margin="0,0,0,10" />
                    <Grid>
                      <TextBlock Text="Pan" Foreground="#B8C7D9" />
                      <TextBlock Text="{Binding PanDisplayText}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                    </Grid>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Pan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="25" ValueChanged="MixerChannelControlChanged" Margin="0,0,0,10" />
                    <Grid>
                      <TextBlock Text="Delay" Foreground="#B8C7D9" />
                      <TextBlock Text="{Binding DelayDisplayText}" Foreground="#F8FAFC" HorizontalAlignment="Right" />
                    </Grid>
                    <Slider Minimum="0" Maximum="250" Value="{Binding DelayMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="5" ValueChanged="MixerChannelControlChanged" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
