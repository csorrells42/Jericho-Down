                  <Button.ToolTip>
                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Starts a podcast session, creates its output folder, turns on camera preview if needed, and begins the recording timer." />
                  </Button.ToolTip>
                </Button>
                <Button x:Name="PauseRecordingButton" Style="{StaticResource RecordingPauseButton}" Content="Pause" Width="92" Padding="12,7" Margin="0,0,8,0" IsEnabled="False" Click="PauseRecordingClicked">
