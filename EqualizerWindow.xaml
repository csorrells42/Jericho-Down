<Window x:Class="VoiceWorkbench.EqualizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podcast Workbench"
        Height="820"
        Width="1400"
        MinHeight="680"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#05070A"
        Loaded="WindowLoaded"
        Activated="WindowActivated"
        Deactivated="WindowDeactivated"
        Closing="WindowClosing"
        KeyDown="WindowKeyDown">
    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="360" />
            <Setter Property="Placement" Value="Mouse" />
            <Setter Property="Background" Value="#111820" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#334F5D6B" />
        </Style>
        <Style x:Key="WrappedToolTipText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="MaxWidth" Value="340" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#18222B" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#4F5D6B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#243241" />
                    <Setter Property="BorderBrush" Value="#60A5FA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#111820" />
                    <Setter Property="Foreground" Value="#64748B" />
                    <Setter Property="BorderBrush" Value="#26323D" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="RepeatButton">
            <Setter Property="Background" Value="#18222B" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#4F5D6B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#243241" />
                    <Setter Property="BorderBrush" Value="#60A5FA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#111820" />
                    <Setter Property="Foreground" Value="#64748B" />
                    <Setter Property="BorderBrush" Value="#26323D" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#18222B" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#4F5D6B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#243241" />
                    <Setter Property="BorderBrush" Value="#60A5FA" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="BorderBrush" Value="#60A5FA" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#111820" />
                    <Setter Property="Foreground" Value="#64748B" />
                    <Setter Property="BorderBrush" Value="#26323D" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0B1118" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="CaretBrush" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#4F5D6B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="SelectionBrush" Value="#2563EB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#111820" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#111820" />
                    <Setter Property="Foreground" Value="#64748B" />
                    <Setter Property="BorderBrush" Value="#26323D" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#0B1118" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="CaretBrush" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#4F5D6B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="SelectionBrush" Value="#2563EB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#111820" />
                    <Setter Property="Foreground" Value="#64748B" />
                    <Setter Property="BorderBrush" Value="#26323D" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0B1118" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#4F5D6B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Margin="0,0,6,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="v"
                                               Foreground="#B8C7D9"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#0B1118"
                                        BorderBrush="#4F5D6B"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer Background="#0B1118">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#111820" />
                    <Setter Property="Foreground" Value="#64748B" />
                    <Setter Property="BorderBrush" Value="#26323D" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0B1118" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#05070A" />
            <Setter Property="Foreground" Value="#334F5D6B" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Background="#05070A"
                                                  BorderBrush="#05070A"
                                                  BorderThickness="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#334F5D6B"
                                           BorderBrush="#4F5D6B"
                                           BorderThickness="1">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Background="#05070A"
                                                  BorderBrush="#05070A"
                                                  BorderThickness="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="12" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0B1118" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#334F5D6B" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#05070A" />
            <Setter Property="BorderBrush" Value="#26323D" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1118" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#334F5D6B" />
            <Setter Property="HorizontalGridLinesBrush" Value="#26323D" />
            <Setter Property="VerticalGridLinesBrush" Value="#1C2732" />
            <Setter Property="RowBackground" Value="#111820" />
            <Setter Property="AlternatingRowBackground" Value="#162231" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#18222B" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#334F5D6B" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#1C2732" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#26323D" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRowHeader">
            <Setter Property="Background" Value="#18222B" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#334F5D6B" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#C0111820"
                Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Camera"
                               Foreground="#F8FAFC"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox x:Name="CameraComboBox"
                              Width="210"
                              SelectionChanged="CameraSelectionChanged" />
                    <TextBlock Text="Mode"
                               Foreground="#B8C7D9"
                               VerticalAlignment="Center"
                               Margin="10,0,8,0" />
                    <ComboBox x:Name="CameraModeComboBox"
                              Width="190"
                              SelectionChanged="CameraModeSelectionChanged" />
                    <ToggleButton x:Name="CameraEnabledToggle"
                                  Content="Camera Off"
                                  Width="104"
                                  Margin="8,0,14,0"
                                  Padding="10,6"
                                  Checked="CameraEnabledChanged"
                                  Unchecked="CameraEnabledChanged">
                        <ToggleButton.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Enable or disable webcam capture for this podcast session. The selected camera stays remembered while disabled." />
                        </ToggleButton.ToolTip>
                    </ToggleButton>
                    <TextBlock Text="Mic" Foreground="#F8FAFC" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="MicrophoneComboBox"
                              Width="220"
                              SelectionChanged="MicrophoneSelectionChanged" />
                    <TextBlock Text="Channel"
                               Foreground="#B8C7D9"
                               VerticalAlignment="Center"
                               Margin="14,0,8,0" />
                    <ComboBox x:Name="InputChannelComboBox"
                              Width="112"
                              SelectionChanged="InputChannelSelectionChanged" />
                    <TextBlock Text="Gain"
                               Foreground="#B8C7D9"
                               VerticalAlignment="Center"
                               Margin="14,0,8,0" />
                    <Slider x:Name="DisplayGainSlider"
                            Loaded="DisplayGainSliderLoaded"
                            ValueChanged="DisplayGainSliderValueChanged"
                            Width="140"
                            Minimum="1"
                            Maximum="24"
                            Value="6"
                            VerticalAlignment="Center">
                        <Slider.Template>
                            <ControlTemplate TargetType="Slider">
                                <Grid>
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="Slider.DecreaseLarge"
                                                          Background="#26323D"
                                                          BorderBrush="#536575"
                                                          BorderThickness="1"
                                                          IsTabStop="False" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="Slider.IncreaseLarge"
                                                          Background="#18222B"
                                                          BorderBrush="#536575"
                                                          BorderThickness="1"
                                                          IsTabStop="False" />
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Width="8"
                                                   Height="18"
                                                   Background="#F8FAFC"
                                                   BorderBrush="#93A4B8"
                                                   BorderThickness="1" />
                                        </Track.Thumb>
                                    </Track>
                                    <Rectangle Width="2"
                                               Fill="#F4C542"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Stretch"
                                               Margin="31,2,0,2" />
                                </Grid>
                            </ControlTemplate>
                        </Slider.Template>
                    </Slider>
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Foreground="#B8C7D9"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="PeakText" Text="Peak 0%" Foreground="#F8FAFC" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <Button Content="Close" Click="CloseClicked" Padding="14,7" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabControl"
                    Grid.Row="1"
                    Background="#05070A"
                    BorderBrush="#26323D"
                    BorderThickness="1"
                    Foreground="#F8FAFC"
                    Padding="4,3,4,4">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="16,6" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Background" Value="#111820" />
                    <Setter Property="Foreground" Value="#B8C7D9" />
                    <Setter Property="BorderBrush" Value="#334F5D6B" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Margin" Value="0,0,2,0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid SnapsToDevicePixels="True">
                                    <Border x:Name="TabChrome"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,1,1,0"
                                            CornerRadius="2,2,0,0"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                                          RecognizesAccessKey="True" />
                                    </Border>
                                    <Rectangle x:Name="SelectedUnderline"
                                               Height="2"
                                               Fill="#38BDF8"
                                               VerticalAlignment="Bottom"
                                               Visibility="Collapsed" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabChrome" Property="Background" Value="#18222B" />
                                        <Setter TargetName="TabChrome" Property="BorderBrush" Value="#334F5D6B" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabChrome" Property="Background" Value="#0B1118" />
                                        <Setter TargetName="TabChrome" Property="BorderBrush" Value="#334F5D6B" />
                                        <Setter TargetName="SelectedUnderline" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0B1118" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter Property="BorderBrush" Value="#334F5D6B" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>
            <TabItem Header="Video / Recording">
                <Grid Background="#05070A">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#C0111820"
                        Padding="18,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="RecordingTimerText"
                                       Text="00:00:00"
                                       Foreground="#F8FAFC"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0" />
                            <Button x:Name="StartRecordingButton"
                                    Content="Start"
                                    Padding="16,7"
                                    Margin="0,0,6,0"
                                    Click="StartRecordingClicked">
                                <Button.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Starts a podcast session, creates its output folder, turns on camera preview if needed, and begins the recording timer." />
                                </Button.ToolTip>
                            </Button>
                            <Button x:Name="PauseRecordingButton"
                                    Content="Pause"
                                    Padding="16,7"
                                    Margin="0,0,6,0"
                                    IsEnabled="False"
                                    Click="PauseRecordingClicked">
                                <Button.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Pauses or resumes the current recording session timer. File capture will use this same transport state." />
                                </Button.ToolTip>
                            </Button>
                            <Button x:Name="StopRecordingButton"
                                    Content="Stop"
                                    Padding="16,7"
                                    IsEnabled="False"
                                    Click="StopRecordingClicked">
                                <Button.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Stops the current recording session and prepares the next session folder." />
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="420" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#030507"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1">
                        <Grid>
                            <Rectangle Fill="#05070A" />
                            <Image x:Name="CameraPreviewImage"
                                   Visibility="Collapsed"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True" />
                            <StackPanel x:Name="CameraPlaceholder"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Video Preview"
                                           Foreground="#F8FAFC"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="CameraPreviewStatusText"
                                           Text="Camera disabled"
                                           Foreground="#B8C7D9"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#AA111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="14,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Audio Confidence"
                                       Foreground="#F8FAFC"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Ellipse x:Name="RecordingDspIndicator"
                                         Width="14"
                                         Height="14"
                                         Fill="#42D77D"
                                         Stroke="#B8C7D9"
                                         StrokeThickness="1"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0" />
                                <TextBlock x:Name="RecordingDspStatusText"
                                           Text="DSP active"
                                           Foreground="#B8C7D9"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Border Height="130"
                                    Background="#05070A"
                                    BorderBrush="#334F5D6B"
                                    BorderThickness="1"
                                    Margin="0,0,0,10">
                                <Canvas x:Name="RecordingSignalCanvas" />
                            </Border>
                            <TextBlock Text="Processed signal being monitored"
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14" />
                            <CheckBox x:Name="RecordProcessedAudioCheckBox"
                                      Content="Record processed audio"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      Margin="0,0,0,8">
                                <CheckBox.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="When checked, the eventual video file will use the EQ/gate/compressor/limiter signal." />
                                </CheckBox.ToolTip>
                            </CheckBox>
                            <CheckBox x:Name="RecordRawBackupCheckBox"
                                      Content="Also save raw backup"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      Margin="0,0,0,14">
                                <CheckBox.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Keeps a natural unprocessed WAV backup so a session can be fixed later." />
                                </CheckBox.ToolTip>
                            </CheckBox>
                            <TextBlock Text="Session Outputs"
                                       Foreground="#F8FAFC"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#05070A"
                                        BorderBrush="#334F5D6B"
                                        BorderThickness="1"
                                        Padding="8,6"
                                        Margin="0,0,8,0">
                                    <TextBlock x:Name="OutputFolderText"
                                               Foreground="#B8C7D9"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding ElementName=OutputFolderText, Path=Text}" />
                                </Border>
                                <Button Grid.Column="1"
                                        Content="Browse"
                                        Padding="12,6"
                                        Click="BrowseOutputFolderClicked">
                                    <Button.ToolTip>
                                        <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Choose where podcast session folders and recording files will be saved." />
                                    </Button.ToolTip>
                                </Button>
                            </Grid>
                            <TextBlock Text="Each recording creates its own folder:"
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4" />
                            <TextBlock x:Name="NextSessionFolderText"
                                       Foreground="#F8FAFC"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding ElementName=NextSessionFolderText, Path=Text}"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="NextRecordingFilesText"
                                       Text="video_001.mp4&#x0a;mix_001.wav&#x0a;raw_backup_001.wav&#x0a;session.json"
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16" />
                            <TextBlock Text="Camera Image"
                                       Foreground="#F8FAFC"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <CheckBox x:Name="VideoDenoiseCheckBox"
                                      Content="Reduce video grain"
                                      Foreground="#F8FAFC"
                                      Margin="0,0,0,8"
                                      Checked="VideoDenoiseChanged"
                                      Unchecked="VideoDenoiseChanged">
                                <CheckBox.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Applies temporal/spatial denoise to the preview. It can smooth grain from low light, but too much can make motion look waxy." />
                                </CheckBox.ToolTip>
                            </CheckBox>
                            <Grid Margin="0,0,0,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Denoise strength"
                                           Foreground="#B8C7D9"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="VideoDenoiseValueText"
                                           Grid.Column="1"
                                           Text="2.0"
                                           Foreground="#F8FAFC"
                                           FontWeight="SemiBold"
                                           Margin="8,0,0,0" />
                                <Slider x:Name="VideoDenoiseSlider"
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Minimum="0.5"
                                        Maximum="8"
                                        Value="2"
                                        TickPlacement="BottomRight"
                                        TickFrequency="0.5"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="VideoDenoiseChanged" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Camera Controls"
                                           Foreground="#F8FAFC"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <Button Grid.Column="1"
                                        Content="Refresh"
                                        Padding="10,4"
                                        Click="RefreshCameraControlsClicked">
                                    <Button.ToolTip>
                                        <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Reloads the controls the selected camera exposes through Windows, such as focus, exposure, zoom, white balance, brightness, and gain." />
                                    </Button.ToolTip>
                                </Button>
                            </Grid>
                            <TextBlock x:Name="CameraControlStatusText"
                                       Text="Choose a camera to load controls."
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <StackPanel x:Name="CameraControlPanel" />
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Background="#66111820"
                        Padding="18,10">
                    <TextBlock x:Name="RecordingStatusText"
                               Text="Ready to record. Use Mic / DSP to tune the sound."
                               Foreground="#B8C7D9" />
                </Border>
            </Grid>
            </TabItem>
            <TabItem Header="Security Cam">
                <Grid Background="#05070A" Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="420" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#030507"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1">
                        <Grid>
                            <Rectangle Fill="#05070A" />
                            <Image x:Name="SecurityWatchPreviewImage"
                                   Visibility="Collapsed"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True" />
                            <StackPanel x:Name="SecurityWatchPlaceholder"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Security Cam"
                                           Foreground="#F8FAFC"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="SecurityWatchStateText"
                                           Text="Camera disabled"
                                           Foreground="#B8C7D9"
                                           FontSize="14"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#AA111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="14,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Security Cam"
                                           Foreground="#F8FAFC"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Uses the selected camera to log motion events and optional snapshots."
                                           Foreground="#B8C7D9"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />
                                <CheckBox x:Name="SecurityWatchEnabledCheckBox"
                                          Content="Enable motion watch"
                                          Foreground="#F8FAFC"
                                          Margin="0,0,0,8"
                                          Checked="SecurityWatchEnabledChanged"
                                          Unchecked="SecurityWatchEnabledChanged">
                                    <CheckBox.ToolTip>
                                        <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Logs frame-to-frame motion events using the live camera preview." />
                                    </CheckBox.ToolTip>
                                </CheckBox>
                                <CheckBox x:Name="SecurityWatchSnapshotCheckBox"
                                          Content="Save snapshot on motion"
                                          IsChecked="True"
                                          Foreground="#F8FAFC"
                                          Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Motion threshold"
                                               Foreground="#B8C7D9" />
                                    <TextBlock x:Name="SecurityWatchThresholdValueText"
                                               Grid.Column="1"
                                               Text="8.0%"
                                               Foreground="#F8FAFC"
                                               FontWeight="SemiBold" />
                                </Grid>
                                <Slider x:Name="SecurityWatchThresholdSlider"
                                        Minimum="1"
                                        Maximum="30"
                                        Value="8"
                                        TickFrequency="1"
                                        TickPlacement="BottomRight"
                                        ValueChanged="SecurityWatchSettingChanged"
                                        Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Snapshot cooldown"
                                               Foreground="#B8C7D9" />
                                    <TextBlock x:Name="SecurityWatchCooldownValueText"
                                               Grid.Column="1"
                                               Text="5s"
                                               Foreground="#F8FAFC"
                                               FontWeight="SemiBold" />
                                </Grid>
                                <Slider x:Name="SecurityWatchCooldownSlider"
                                        Minimum="1"
                                        Maximum="60"
                                        Value="5"
                                        TickFrequency="1"
                                        TickPlacement="BottomRight"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="SecurityWatchSettingChanged"
                                        Margin="0,0,0,8" />
                                <TextBlock x:Name="SecurityWatchStatusText"
                                           Text="Security cam idle."
                                           Foreground="#B8C7D9"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <DataGrid x:Name="SecurityWatchEventGrid"
                                          Height="260"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Background="#0B1118"
                                          Foreground="#F8FAFC"
                                          BorderBrush="#334F5D6B"
                                          GridLinesVisibility="Horizontal"
                                          RowBackground="#111820"
                                          AlternatingRowBackground="#162231"
                                          Margin="0,0,0,12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding TimeLabel}" Width="90" />
                                        <DataGridTextColumn Header="Event" Binding="{Binding Event}" Width="*" />
                                        <DataGridTextColumn Header="Motion" Binding="{Binding Motion}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Mic / DSP">
                <Grid Background="#05070A">
        <Canvas x:Name="SpectrumCanvas" Background="#05070A" Margin="0,0,360,0" />
        <Canvas x:Name="WaveformCanvas" Background="#05070A" Margin="0,0,360,0" Visibility="Collapsed" />

        <Border HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="#C0111820"
                Padding="18,12"
                Margin="0,0,360,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel x:Name="NormalSpectrumLegendPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <TextBlock Text="Raw" Foreground="#A7B0BC" VerticalAlignment="Center" />
                        <Rectangle Width="24" Height="2" Fill="#A7B0BC" Margin="6,0,12,0" />
                        <TextBlock Text="Processed" Foreground="#00BEE6" VerticalAlignment="Center" />
                        <Rectangle Width="24" Height="3" Fill="#00BEE6" Margin="6,0,12,0" />
                        <TextBlock Text="Average" Foreground="#D7B220" VerticalAlignment="Center" />
                        <Rectangle Width="24" Height="2" Fill="#D7B220" Margin="6,0,0,0" />
                    </StackPanel>
                    <StackPanel x:Name="MicCompareLegendPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="Mic 1" Foreground="#00BEE6" VerticalAlignment="Center" />
                        <Rectangle Width="24" Height="3" Fill="#00BEE6" Margin="6,0,12,0" />
                        <TextBlock Text="Mic 2" Foreground="#FF5252" VerticalAlignment="Center" />
                        <Rectangle Width="24" Height="3" Fill="#FF5252" Margin="6,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Button x:Name="SpectrumViewButton"
                                Content="Spectrum"
                                Click="SpectrumViewClicked"
                                Padding="10,4"
                                Margin="0,0,6,0" />
                        <Button x:Name="WaveformViewButton"
                                Content="Waveform"
                                Click="WaveformViewClicked"
                                Padding="10,4"
                                Margin="0,0,6,0">
                            <Button.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Shows raw and processed microphone amplitude around the centerline." />
                            </Button.ToolTip>
                        </Button>
                        <Button x:Name="MicCompareViewButton"
                                Content="Mic Compare"
                                Click="MicCompareViewClicked"
                                Padding="10,4">
                            <Button.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Shows input 1 and input 2 as raw, unprocessed spectrum lines so two microphones can be compared directly." />
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="Time"
                                   Foreground="#B8C7D9"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <Slider x:Name="WaveformTimeSlider"
                                Width="110"
                                Minimum="25"
                                Maximum="1000"
                                Value="120"
                                TickFrequency="100"
                                VerticalAlignment="Center">
                            <Slider.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Controls how much time the waveform shows. Lower values zoom in and feel faster; higher values zoom out and feel slower." />
                            </Slider.ToolTip>
                        </Slider>
                        <TextBlock Text="{Binding ElementName=WaveformTimeSlider, Path=Value, StringFormat={}{0:0} ms}"
                                   Foreground="#F8FAFC"
                                   Width="48"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0" />
                        <CheckBox x:Name="WaveformTriggerCheckBox"
                                  Content="Lock"
                                  IsChecked="True"
                                  Foreground="#F8FAFC"
                                  VerticalAlignment="Center"
                                  Margin="10,0,0,0">
                            <CheckBox.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Starts the waveform near a rising center crossing so the display behaves more like a triggered oscilloscope." />
                            </CheckBox.ToolTip>
                        </CheckBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Background="#66111820"
                Padding="10"
                Margin="18,0,378,18">
            <ItemsControl x:Name="EqBandPanel"
                          VerticalAlignment="Bottom"
                          HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#99111820"
                                BorderBrush="#334F5D6B"
                                BorderThickness="1"
                                Padding="3"
                                Margin="1">
                            <Grid Height="210">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="{Binding Label}"
                                           Foreground="#B8C7D9"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,3" />
                                <Slider Grid.Row="1"
                                        Loaded="EqSliderLoaded"
                                        ValueChanged="EqSliderValueChanged"
                                        Minimum="-12"
                                        Maximum="12"
                                        Value="{Binding GainDb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Orientation="Vertical"
                                        TickFrequency="3"
                                        IsSnapToTickEnabled="False">
                                    <Slider.Template>
                                        <ControlTemplate TargetType="Slider">
                                            <Grid>
                                                <Track x:Name="PART_Track"
                                                       IsDirectionReversed="True">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                                      Background="#26323D"
                                                                      BorderBrush="#536575"
                                                                      BorderThickness="1"
                                                                      IsTabStop="False" />
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                                      Background="#18222B"
                                                                      BorderBrush="#536575"
                                                                      BorderThickness="1"
                                                                      IsTabStop="False" />
                                                    </Track.IncreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb Width="18"
                                                               Height="8"
                                                               Background="#F8FAFC"
                                                               BorderBrush="#93A4B8"
                                                               BorderThickness="1" />
                                                    </Track.Thumb>
                                                </Track>
                                                <Rectangle Height="2"
                                                           Fill="#F4C542"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0" />
                                            </Grid>
                                        </ControlTemplate>
                                    </Slider.Template>
                                </Slider>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding GainDb, StringFormat={}{0:+0;-0;0}}"
                                           Foreground="#F8FAFC"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="360"
                Background="#AA111820"
                BorderBrush="#334F5D6B"
                BorderThickness="1,0,0,0"
                Padding="14"
                Margin="0,64,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,12,0">
                    <Border x:Name="MicAnalysisPanel"
                            Background="#6618242E"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Mic Analysis"
                                       Foreground="#F8FAFC"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Test mode"
                                       Foreground="#B8C7D9" />
                            <ComboBox x:Name="MicAnalysisModeComboBox"
                                      SelectedIndex="0"
                                      Margin="0,2,0,8">
                                <ComboBoxItem Content="Simultaneous" />
                                <ComboBoxItem Content="Sequential" />
                            </ComboBox>
                            <CheckBox x:Name="MicAnalysisNormalizeCheckBox"
                                      Content="Normalize volume"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      Margin="0,0,0,8">
                                <CheckBox.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Level-matches the louder microphone downward before drawing conclusions, so the report focuses on tone instead of gain mismatch." />
                                </CheckBox.ToolTip>
                            </CheckBox>
                            <Button x:Name="StartMicAnalysisButton"
                                    Content="Start mic test"
                                    Click="StartMicAnalysisClicked"
                                    Margin="0,0,0,8">
                                <Button.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Simultaneous mode compares both raw mic channels while you speak once. Sequential mode prompts mic 1 first, then mic 2, and compares the two passes after level matching." />
                                </Button.ToolTip>
                            </Button>
                            <TextBlock x:Name="MicAnalysisStatusText"
                                       Text="Use Mic Compare, then start a test and speak normally."
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Border Height="14"
                                    Background="#18222B"
                                    BorderBrush="#536575"
                                    BorderThickness="1"
                                    Margin="0,0,0,8">
                                <Grid>
                                    <Rectangle x:Name="MicAnalysisProgressMeter"
                                               Fill="#00BEE6"
                                               HorizontalAlignment="Left"
                                               Width="0" />
                                </Grid>
                            </Border>
                            <TextBlock x:Name="MicAnalysisResultText"
                                       Text="No analysis yet."
                                       Foreground="#F8FAFC"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Presets" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Button Content="Flat" Click="FlatPresetClicked" Margin="0,0,0,6">
                        <Button.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Reset EQ and processing to a neutral starting point." />
                        </Button.ToolTip>
                    </Button>
                    <Button Content="Podcast Clean" Click="PodcastCleanPresetClicked" Margin="0,0,0,6">
                        <Button.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Reduces rumble and mud, adds clarity, and uses moderate compression." />
                        </Button.ToolTip>
                    </Button>
                    <Button Content="Warm Radio" Click="WarmRadioPresetClicked" Margin="0,0,0,6">
                        <Button.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Adds body and warmth with smoother highs and medium compression." />
                        </Button.ToolTip>
                    </Button>
                    <Button Content="Noisy Room" Click="NoisyRoomPresetClicked" Margin="0,0,0,6">
                        <Button.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Uses a stronger gate and low-cut to fight background noise." />
                        </Button.ToolTip>
                    </Button>
                    <Button Content="Bright Headset" Click="BrightHeadsetPresetClicked" Margin="0,0,0,8">
                        <Button.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Adds presence and clarity for darker headset microphones." />
                        </Button.ToolTip>
                    </Button>
                    <TextBlock x:Name="PresetDescriptionText"
                               Text="Choose a preset to load a starting point. Yellow ticks show that preset's home settings."
                               Foreground="#B8C7D9"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <TextBlock Text="Output" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Send to" Foreground="#B8C7D9" />
                    <ComboBox x:Name="OutputDeviceComboBox"
                              SelectionChanged="OutputDeviceSelectionChanged"
                              Margin="0,2,0,8" />
                    <CheckBox x:Name="ProcessedOutputCheckBox"
                              Content="Send processed mic"
                              Checked="ProcessedOutputChanged"
                              Unchecked="ProcessedOutputChanged"
                              Foreground="#F8FAFC"
                              Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Sends the blue processed signal to the selected playback endpoint. To feed podcast software, choose a virtual cable input here, then choose the matching virtual cable output as the mic inside the podcast app." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <TextBlock x:Name="OutputStatusText"
                               Text="Output off. Pick a virtual cable input when you want podcast routing."
                               Foreground="#B8C7D9"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <TextBlock Text="Test Clip" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Button x:Name="RecordClipButton" Content="Record 10 seconds" Click="RecordClipClicked" Margin="0,0,0,6">
                        <Button.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Records up to 10 seconds of raw microphone audio. Use the same clip to test different settings without repeating yourself." />
                        </Button.ToolTip>
                    </Button>
                    <Button x:Name="PlayClipButton" Content="Loop test clip" Click="PlayClipClicked" IsEnabled="False" Margin="0,0,0,6">
                        <Button.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Loops the recorded clip through the current processing so you can move controls and compare the result." />
                        </Button.ToolTip>
                    </Button>
                    <Button Content="Return to live mic" Click="ReturnToLiveMicClicked" Margin="0,0,0,6">
                        <Button.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Stops test playback and listens to the selected microphone again." />
                        </Button.ToolTip>
                    </Button>
                    <Border Height="16"
                            Background="#18222B"
                            BorderBrush="#536575"
                            BorderThickness="1"
                            Margin="0,0,0,6">
                        <Grid>
                            <Rectangle x:Name="ClipProgressMeter"
                                       Fill="#00BEE6"
                                       HorizontalAlignment="Left"
                                       Width="0" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="ClipStatusText"
                               Text="No test clip recorded"
                               Foreground="#B8C7D9"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <TextBlock Text="A/B Compare" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <UniformGrid Columns="2" Margin="0,0,0,6">
                        <Button x:Name="StoreAButton" Content="Store A" Click="StoreAClicked" Margin="0,0,3,0">
                            <Button.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Save the current EQ and processing controls into slot A." />
                            </Button.ToolTip>
                        </Button>
                        <Button x:Name="StoreBButton" Content="Store B" Click="StoreBClicked" Margin="3,0,0,0">
                            <Button.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Save the current EQ and processing controls into slot B." />
                            </Button.ToolTip>
                        </Button>
                    </UniformGrid>
                    <UniformGrid Columns="2" Margin="0,0,0,6">
                        <Button x:Name="LoadAButton" Content="Hear A" Click="LoadAClicked" IsEnabled="False" Margin="0,0,3,0">
                            <Button.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Load slot A instantly. Works especially well while the test clip is looping." />
                            </Button.ToolTip>
                        </Button>
                        <Button x:Name="LoadBButton" Content="Hear B" Click="LoadBClicked" IsEnabled="False" Margin="3,0,0,0">
                            <Button.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Load slot B instantly. Flip between A and B to judge which setting is clearer." />
                            </Button.ToolTip>
                        </Button>
                    </UniformGrid>
                    <TextBlock x:Name="CompareStatusText"
                               Text="Store A and B, then flip between them while the clip loops."
                               Foreground="#B8C7D9"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <TextBlock Text="Meters" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock x:Name="InputCoachText" Text="Input: waiting for signal" Foreground="#B8C7D9" />
                    <Border Height="16"
                            Background="#18222B"
                            BorderBrush="#536575"
                            BorderThickness="1"
                            Margin="0,4,0,10">
                        <Grid>
                            <Rectangle x:Name="InputLevelMeter"
                                       Fill="#42D77D"
                                       HorizontalAlignment="Left"
                                       Width="0" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="GainReductionText" Text="Compressor: 0.0 dB" Foreground="#B8C7D9" />
                    <Border Height="16"
                            Background="#18222B"
                            BorderBrush="#536575"
                            BorderThickness="1"
                            Margin="0,4,0,10">
                        <Grid>
                            <Rectangle x:Name="GainReductionMeter"
                                       Fill="#D7B220"
                                       HorizontalAlignment="Left"
                                       Width="0" />
                        </Grid>
                    </Border>
                    <Border Height="44" Margin="0,0,0,10">
                        <TextBlock x:Name="CompressorStateText"
                                   Text="Compressor below threshold"
                                   Foreground="#B8C7D9"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.ToolTip>
                                <TextBlock Style="{StaticResource WrappedToolTipText}" Text="The compressor meter moves only when your voice rises above the threshold. Lower the threshold or raise input level to see more compression." />
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse x:Name="GateIndicator"
                                 Width="16"
                                 Height="16"
                                 Fill="#42D77D"
                                 Stroke="#B8C7D9"
                                 StrokeThickness="1"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0" />
                        <TextBlock x:Name="GateStateText"
                                   Text="Gate open"
                                   Foreground="#B8C7D9"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Processing" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <CheckBox Content="High-pass filter" IsChecked="{Binding HighPassEnabled}" Foreground="#F8FAFC" Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Cuts low rumble below the selected frequency. Useful for desk vibration, HVAC, handling noise, and plosives." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Grid>
                        <TextBlock Text="HPF Hz" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=HighPassSlider, Path=Value, StringFormat={}{0:0} Hz}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="HighPassSlider" Minimum="40" Maximum="180" Value="{Binding HighPassFrequencyHz}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Higher values remove more low end. Drag near the yellow preset tick to return home." />
                        </Slider.ToolTip>
                    </Slider>

                    <CheckBox Content="De-popper" IsChecked="{Binding DePopperEnabled}" Foreground="#F8FAFC" Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Tames low-frequency plosive bursts from P and B sounds without lowering the whole voice." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Grid>
                        <TextBlock Text="Pop reduction" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=DePopperSlider, Path=Value, StringFormat={}{0:0.0} dB}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="DePopperSlider" Minimum="0" Maximum="12" Value="{Binding DePopperAmountDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="How strongly low plosive bursts are reduced. Too much can thin out close mic warmth." />
                        </Slider.ToolTip>
                    </Slider>

                    <CheckBox Content="Noise gate" IsChecked="{Binding NoiseGateEnabled}" Foreground="#F8FAFC" Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Turns down quiet background noise when you are not speaking." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Grid>
                        <TextBlock Text="Gate dB" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=GateThresholdSlider, Path=Value, StringFormat={}{0:+0;-0;0} dB}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="GateThresholdSlider" Minimum="-70" Maximum="-20" Value="{Binding NoiseGateThresholdDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Less negative values make the gate stricter. More negative values let quieter sound through." />
                        </Slider.ToolTip>
                    </Slider>

                    <CheckBox Content="Noise suppression" IsChecked="{Binding NoiseSuppressionEnabled}" Foreground="#F8FAFC" Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Gently turns down steady low-level room or computer noise under your voice." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Grid>
                        <TextBlock Text="Noise reduction" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=NoiseSuppressionSlider, Path=Value, StringFormat={}{0:0.0} dB}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="NoiseSuppressionSlider" Minimum="0" Maximum="18" Value="{Binding NoiseSuppressionAmountDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="How much steady background noise is reduced. Too much can make quiet speech sound unnatural." />
                        </Slider.ToolTip>
                    </Slider>

                    <CheckBox Content="Echo reducer" IsChecked="{Binding EchoReducerEnabled}" Foreground="#F8FAFC" Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Reduces quiet room reflection tails after louder syllables. This is not full speaker-reference acoustic echo cancellation yet." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Grid>
                        <TextBlock Text="Echo reduction" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=EchoReducerSlider, Path=Value, StringFormat={}{0:0.0} dB}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="EchoReducerSlider" Minimum="0" Maximum="12" Value="{Binding EchoReducerAmountDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="How strongly room echo tails are reduced. Too much can make sentence endings feel chopped." />
                        </Slider.ToolTip>
                    </Slider>

                    <CheckBox Content="Compressor" IsChecked="{Binding CompressorEnabled}" Foreground="#F8FAFC" Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Turns down louder moments so your voice level is more even." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Grid>
                        <TextBlock Text="Comp threshold" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=CompressorThresholdSlider, Path=Value, StringFormat={}{0:+0;-0;0} dB}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="CompressorThresholdSlider" Minimum="-36" Maximum="-6" Value="{Binding CompressorThresholdDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="The level where compression starts. Lower it to compress more often." />
                        </Slider.ToolTip>
                    </Slider>
                    <Grid>
                        <TextBlock Text="Comp ratio" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=CompressorRatioSlider, Path=Value, StringFormat={}{0:0.0}:1}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="CompressorRatioSlider" Minimum="1" Maximum="8" Value="{Binding CompressorRatio}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="How strongly loud parts are turned down after crossing the threshold." />
                        </Slider.ToolTip>
                    </Slider>

                    <CheckBox Content="De-esser" IsChecked="{Binding DeEsserEnabled}" Foreground="#F8FAFC" Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Tames sharp S, sh, and hiss energy in the sibilance band without dulling the entire voice." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Grid>
                        <TextBlock Text="Ess reduction" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=DeEsserSlider, Path=Value, StringFormat={}{0:0.0} dB}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="DeEsserSlider" Minimum="0" Maximum="12" Value="{Binding DeEsserAmountDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="How strongly sharp sibilance is reduced. Too much can make speech sound lispy." />
                        </Slider.ToolTip>
                    </Slider>

                    <CheckBox Content="Limiter" IsChecked="{Binding LimiterEnabled}" Foreground="#F8FAFC" Margin="0,0,0,6">
                        <CheckBox.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="A final safety ceiling that catches peaks before clipping." />
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Grid>
                        <TextBlock Text="Makeup dB" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=MakeupGainSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0} dB}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="MakeupGainSlider" Minimum="-6" Maximum="12" Value="{Binding MakeupGainDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,10">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Raises or lowers the processed voice after compression." />
                        </Slider.ToolTip>
                    </Slider>
                    <Grid>
                        <TextBlock Text="Limiter ceiling" Foreground="#B8C7D9" />
                        <TextBlock Text="{Binding ElementName=LimiterCeilingSlider, Path=Value, StringFormat={}{0:+0.0;-0.0;0.0} dB}"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider x:Name="LimiterCeilingSlider" Minimum="-6" Maximum="0" Value="{Binding LimiterCeilingDb}" TickPlacement="BottomRight" ValueChanged="ProcessingSliderValueChanged" Margin="0,0,0,16">
                        <Slider.ToolTip>
                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Maximum output level. Keep slightly below 0 dB to avoid clipping." />
                        </Slider.ToolTip>
                    </Slider>

                    <TextBlock Text="What am I seeing?" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Gray is raw mic input. Blue is processed sound after EQ and dynamics. Gold is the smoothed processed average. Yellow ticks are the current preset defaults. The yellow meter shows compressor gain reduction. The gate light shows whether quiet noise is being reduced."
                               Foreground="#B8C7D9"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Wi-Fi Analyzer">
                <Grid Background="#05070A" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="1.25*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#C0111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="RefreshWifiButton"
                                    Content="Refresh Wi-Fi"
                                    Padding="14,7"
                                    Click="RefreshWifiClicked">
                                <Button.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Scans nearby Wi-Fi networks using Windows WLAN data. Windows may require Location permission and administrator rights." />
                                </Button.ToolTip>
                            </Button>
                            <CheckBox x:Name="AutoRefreshWifiCheckBox"
                                      Grid.Column="1"
                                      Content="Auto"
                                      Foreground="#F8FAFC"
                                      VerticalAlignment="Center"
                                      Margin="14,0,18,0"
                                      Checked="AutoRefreshWifiChanged"
                                      Unchecked="AutoRefreshWifiChanged">
                                <CheckBox.ToolTip>
                                    <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Refreshes the Wi-Fi scan every 15 seconds while this app is open." />
                                </CheckBox.ToolTip>
                            </CheckBox>
                            <TextBlock x:Name="WifiStatusText"
                                       Grid.Column="2"
                                       Text="Ready to scan Wi-Fi."
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#030507"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Margin="0,0,0,12"
                            MinHeight="260">
                        <Canvas x:Name="WifiChannelCanvas"
                                Background="#05070A"
                                SizeChanged="WifiChannelCanvasSizeChanged" />
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="330" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="#AA111820"
                                BorderBrush="#334F5D6B"
                                BorderThickness="1"
                                Padding="14"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Selected Network"
                                           Foreground="#F8FAFC"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock x:Name="WifiSelectedNetworkText"
                                           Text="Click a network to inspect it."
                                           Foreground="#B8C7D9"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="WifiNetworkGrid"
                                  Grid.Column="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Background="#0B1118"
                                  Foreground="#F8FAFC"
                                  BorderBrush="#334F5D6B"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="#111820"
                                  AlternatingRowBackground="#162231"
                                  SelectionMode="Single"
                                  SelectionChanged="WifiNetworkSelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SSID" Binding="{Binding Ssid}" Width="2*" />
                                <DataGridTextColumn Header="Signal" Binding="{Binding SignalLabel}" Width="80" />
                                <DataGridTextColumn Header="Band" Binding="{Binding Band}" Width="90" />
                                <DataGridTextColumn Header="Ch" Binding="{Binding ChannelLabel}" Width="60" />
                                <DataGridTextColumn Header="Seen" Binding="{Binding SeenLabel}" Width="110" />
                                <DataGridTextColumn Header="Radio" Binding="{Binding RadioType}" Width="110" />
                                <DataGridTextColumn Header="Security" Binding="{Binding Authentication}" Width="150" />
                                <DataGridTextColumn Header="BSSID" Binding="{Binding Bssid}" Width="180" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="IP Scanner">
                <Grid Background="#05070A" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#C0111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Start"
                                           Foreground="#F8FAFC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBox x:Name="StartIpOctet1TextBox" Text="192" Width="38" MaxLength="3" TextAlignment="Center" />
                                <TextBlock Text="." Foreground="#B8C7D9" VerticalAlignment="Center" Margin="4,0" />
                                <TextBox x:Name="StartIpOctet2TextBox" Text="168" Width="38" MaxLength="3" TextAlignment="Center" />
                                <TextBlock Text="." Foreground="#B8C7D9" VerticalAlignment="Center" Margin="4,0" />
                                <TextBox x:Name="StartIpOctet3TextBox" Text="1" Width="38" MaxLength="3" TextAlignment="Center" />
                                <TextBlock Text="." Foreground="#B8C7D9" VerticalAlignment="Center" Margin="4,0" />
                                <TextBox x:Name="StartIpOctet4TextBox" Text="1" Width="38" MaxLength="3" TextAlignment="Center" />

                                <TextBlock Text="End"
                                           Foreground="#F8FAFC"
                                           VerticalAlignment="Center"
                                           Margin="18,0,8,0" />
                                <TextBox x:Name="EndIpOctet1TextBox" Text="192" Width="38" MaxLength="3" TextAlignment="Center" />
                                <TextBlock Text="." Foreground="#B8C7D9" VerticalAlignment="Center" Margin="4,0" />
                                <TextBox x:Name="EndIpOctet2TextBox" Text="168" Width="38" MaxLength="3" TextAlignment="Center" />
                                <TextBlock Text="." Foreground="#B8C7D9" VerticalAlignment="Center" Margin="4,0" />
                                <TextBox x:Name="EndIpOctet3TextBox" Text="1" Width="38" MaxLength="3" TextAlignment="Center" />
                                <TextBlock Text="." Foreground="#B8C7D9" VerticalAlignment="Center" Margin="4,0" />
                                <TextBox x:Name="EndIpOctet4TextBox" Text="255" Width="38" MaxLength="3" TextAlignment="Center" />

                                <Button x:Name="StartIpScanButton"
                                        Content="Scan"
                                        Padding="14,7"
                                        Margin="18,0,6,0"
                                        Click="StartIpScanClicked">
                                    <Button.ToolTip>
                                        <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Pings each IPv4 address in the selected range and shows devices that answer." />
                                    </Button.ToolTip>
                                </Button>
                                <Button x:Name="CancelIpScanButton"
                                        Content="Cancel"
                                        Padding="14,7"
                                        IsEnabled="False"
                                        Click="CancelIpScanClicked" />
                            </StackPanel>

                            <TextBlock x:Name="IpScanStatusText"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="Enter a range and scan. Example: 192.168.1.1 to 192.168.1.255."
                                       Foreground="#B8C7D9"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="IpScanResultsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Background="#0B1118"
                                  Foreground="#F8FAFC"
                                  BorderBrush="#334F5D6B"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="#111820"
                                  AlternatingRowBackground="#162231"
                                  SelectionMode="Single"
                                  SelectionChanged="IpScanResultSelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="IP Address" Binding="{Binding Address}" Width="150" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                                <DataGridTextColumn Header="Latency" Binding="{Binding LatencyLabel}" Width="100" />
                                <DataGridTextColumn Header="TTL" Binding="{Binding TtlLabel}" Width="70" />
                                <DataGridTextColumn Header="OS Guess" Binding="{Binding OsGuess}" Width="150" />
                                <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}" Width="160" />
                                <DataGridTextColumn Header="Host Name" Binding="{Binding HostName}" Width="220" />
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1"
                                Background="#AA111820"
                                BorderBrush="#334F5D6B"
                                BorderThickness="1"
                                Padding="14"
                                Margin="12,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Port Scan"
                                               Foreground="#F8FAFC"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="PortScanTargetText"
                                               Text="Select a discovered device."
                                               Foreground="#B8C7D9"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,10" />
                                </StackPanel>

                                <StackPanel Grid.Row="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,0,10">
                                    <Button x:Name="ScanCommonPortsButton"
                                            Content="Common"
                                            Padding="10,6"
                                            IsEnabled="False"
                                            Click="ScanCommonPortsClicked">
                                        <Button.ToolTip>
                                            <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Scans a small set of common TCP ports on the selected device." />
                                        </Button.ToolTip>
                                    </Button>
                                    <TextBox x:Name="PortStartTextBox"
                                             Text="1"
                                             Width="52"
                                             MaxLength="5"
                                             TextAlignment="Center"
                                             Margin="8,0,4,0" />
                                    <TextBlock Text="-"
                                               Foreground="#B8C7D9"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="PortEndTextBox"
                                             Text="1024"
                                             Width="52"
                                             MaxLength="5"
                                             TextAlignment="Center"
                                             Margin="4,0,8,0" />
                                    <Button x:Name="ScanPortRangeButton"
                                            Content="Range"
                                            Padding="10,6"
                                            IsEnabled="False"
                                            Click="ScanPortRangeClicked" />
                                    <Button x:Name="CancelPortScanButton"
                                            Content="Cancel"
                                            Padding="10,6"
                                            Margin="6,0,0,0"
                                            IsEnabled="False"
                                            Click="CancelPortScanClicked" />
                                </StackPanel>

                                <DataGrid x:Name="PortScanResultsGrid"
                                          Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Background="#0B1118"
                                          Foreground="#F8FAFC"
                                          BorderBrush="#334F5D6B"
                                          GridLinesVisibility="Horizontal"
                                          RowBackground="#111820"
                                          AlternatingRowBackground="#162231">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="70" />
                                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="80" />
                                        <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="120" />
                                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Serial">
                <Grid Background="#05070A" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

