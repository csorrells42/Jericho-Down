                                          <Border Width="20" Height="10" BorderBrush="#A7FFF8" BorderThickness="1" CornerRadius="2" SnapsToDevicePixels="True">
                                            <Border.Background>
                                              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
