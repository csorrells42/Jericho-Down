              <ToggleButton x:Name="DropDownToggle" Focusable="False" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Grid SnapsToDevicePixels="True">
                      <Border x:Name="Shadow" Background="#05070A" CornerRadius="5" Margin="0,3,0,0" Opacity="0.9" />
