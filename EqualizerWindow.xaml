          </Setter>
          <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="#0B1118" />
              <Setter Property="Foreground" Value="#FFFFFF" />
              <Setter Property="BorderBrush" Value="#334F5D6B" />
