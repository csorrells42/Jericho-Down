    <Style x:Key="PresetConsoleButton" TargetType="ToggleButton">
      <Setter Property="Background" Value="#1F2A33" />
      <Setter Property="Foreground" Value="#F8FAFC" />
      <Setter Property="BorderBrush" Value="#526879" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Grid SnapsToDevicePixels="True">
              <Border x:Name="Shadow" Background="#05070A" CornerRadius="5" Margin="0,3,0,0" Opacity="0.95" />
              <Border x:Name="Chrome" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Margin="0,0,0,3">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#334251" Offset="0" />
                    <GradientStop Color="#1A252E" Offset="0.5" />
                    <GradientStop Color="#101820" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Grid>
                  <Rectangle Height="1" Fill="#FFFFFF" Opacity="0.16" VerticalAlignment="Top" Margin="7,3,7,0" />
                  <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" />
                </Grid>
              </Border>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="#7DD3FC" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Margin" Value="0,2,0,1" />
                <Setter TargetName="Shadow" Property="Margin" Value="0,2,0,0" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Chrome" Property="Margin" Value="0,3,0,0" />
                <Setter TargetName="Shadow" Property="Opacity" Value="0" />
                <Setter Property="BorderBrush" Value="#35E8D8" />
                <Setter Property="Foreground" Value="#D7FFF9" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#64748B" />
                <Setter Property="BorderBrush" Value="#26323D" />
                <Setter TargetName="Chrome" Property="Opacity" Value="0.62" />
                <Setter TargetName="Shadow" Property="Opacity" Value="0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
