                            Background="#C0111820"
                            BorderBrush="#334F5D6B"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Port" Foreground="#F8FAFC" VerticalAlignment="Center" Margin="0,0,6,0" />
