                      <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Shows raw and processed microphone amplitude around the centerline." />
                    </ToggleButton.ToolTip>
                  </ToggleButton>
                  <ToggleButton x:Name="Waveform3DButton" Style="{StaticResource PresetConsoleButton}" Content="3D Wave" Click="Waveform3DClicked" Padding="10,4" Margin="0,0,6,0">
                    <ToggleButton.ToolTip>
                      <TextBlock Style="{StaticResource WrappedToolTipText}" Text="Shows a GPU-backed 3D rolling waveform using the current processed sound." />
                    </ToggleButton.ToolTip>
                  </ToggleButton>
