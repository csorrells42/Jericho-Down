<Window x:Class="JerichoDown.Waveform3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Waveform"
        Height="520"
        Width="820"
        MinHeight="360"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="#020407">
  <Grid Background="#020407">
    <Viewport3D x:Name="WaveformViewport" ClipToBounds="True">
      <Viewport3D.Camera>
        <PerspectiveCamera x:Name="OrbitCamera"
                           Position="7.6,2.35,5.9"
                           LookDirection="-6.25,-2.55,-5.9"
                           UpDirection="0,1,0"
                           FieldOfView="60" />
      </Viewport3D.Camera>
      <ModelVisual3D>
        <ModelVisual3D.Content>
          <Model3DGroup x:Name="SceneModel">
            <AmbientLight Color="#14202B" />
            <DirectionalLight Color="#F3FDFF" Direction="-0.28,-0.62,-1" />
            <DirectionalLight Color="#2ED7FF" Direction="0.55,-0.18,0.75" />
          </Model3DGroup>
        </ModelVisual3D.Content>
      </ModelVisual3D>
    </Viewport3D>

    <Border HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="#C0111820"
            BorderBrush="#26323D"
            BorderThickness="1"
            Padding="12,8"
            Margin="14">
      <StackPanel Orientation="Horizontal">
        <TextBlock x:Name="ModeText" Text="Processed waveform" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="0,0,14,0" />
        <TextBlock x:Name="PeakText" Text="Peak 0%" Foreground="#F8FAFC" FontWeight="SemiBold" VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <Border HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="#D0111820"
            BorderBrush="#26323D"
            BorderThickness="1"
            Padding="12,10"
            Margin="14">
      <Grid Width="310">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="64" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="54" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Orbit" Foreground="#B8C7D9" VerticalAlignment="Center" />
        <Slider x:Name="OrbitSlider"
                Grid.Row="0"
                Grid.Column="1"
                Minimum="-180"
                Maximum="180"
                Value="63"
                TickFrequency="15"
                ValueChanged="CameraControlChanged" />
        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ElementName=OrbitSlider, Path=Value, StringFormat={}{0:0} deg}" Foreground="#F8FAFC" HorizontalAlignment="Right" VerticalAlignment="Center" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Distance" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="0,8,0,0" />
        <Slider x:Name="DistanceSlider"
                Grid.Row="1"
                Grid.Column="1"
                Minimum="4"
                Maximum="16"
                Value="6.6"
                TickFrequency="0.5"
                ValueChanged="CameraControlChanged"
                Margin="0,8,0,0" />
        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ElementName=DistanceSlider, Path=Value, StringFormat={}{0:0.0}}" Foreground="#F8FAFC" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,8,0,0" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Height" Foreground="#B8C7D9" VerticalAlignment="Center" Margin="0,8,0,0" />
        <Slider x:Name="HeightSlider"
                Grid.Row="2"
                Grid.Column="1"
                Minimum="0.8"
                Maximum="5.2"
                Value="2.35"
                TickFrequency="0.25"
                ValueChanged="CameraControlChanged"
                Margin="0,8,0,0" />
        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ElementName=HeightSlider, Path=Value, StringFormat={}{0:0.0}}" Foreground="#F8FAFC" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,8,0,0" />
      </Grid>
    </Border>
  </Grid>
</Window>
